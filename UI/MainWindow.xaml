<Window x:Class="MacroEngine.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="MacroEngine" 
        Width="1280" Height="760"
        MinWidth="900" MinHeight="560"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <!-- Style spécifique pour les items du ComboBox Mode de déclenchement -->
        <Style x:Key="TriggerModeComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <Grid ToolTip="{Binding Tooltip}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Margin="4,0,0,0" Padding="4,2,4,2"
                                        CornerRadius="3"
                                        BorderBrush="{StaticResource BorderLightBrush}"
                                        BorderThickness="1"
                                        Visibility="{Binding IsRecommended, Converter={StaticResource BoolToVisibilityConverter}}"
                                        ToolTip="Recommandé selon les actions de la macro">
                                    <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="#254FB58C"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                    </Border.Style>
                                    <TextBlock Text="&#xE238;" FontFamily="{StaticResource FontLucide}" FontSize="12"
                                               Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BackgroundTertiaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BackgroundTertiaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--
          Titres de sections barre d’outils (discrets : couleur atténuée, semi-gras, petite taille).
          Fenêtre transparente : ClearType explicite pour un rendu net.
        -->
        <Style x:Key="ToolbarSectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontToolbarSection}"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Opacity" Value="0.88"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
            <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
        </Style>
        <!-- Raccourcis à côté des icônes EXECUTION : même police / couleur que les titres de section, largeur fixe -->
        <Style x:Key="ToolbarShortcutHintStyle" TargetType="TextBlock" BasedOn="{StaticResource ToolbarSectionLabelStyle}">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="10"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- Style barre d'action (boutons type carte) -->
        <Style x:Key="ActionCard" TargetType="Button" BasedOn="{StaticResource ButtonGhost}">
            <Setter Property="Padding" Value="12,6,12,8"/>
            <Setter Property="MinWidth" Value="56"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#161916"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <!-- Root — fenêtre avec bordure custom (style référence) -->
    <Border x:Name="RootBorder" Background="#080A08" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Margin" Value="0"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                        <Setter Property="Margin" Value="7"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════ TITLEBAR ══════════════════════════════════════ -->
            <Border x:Name="TitleBarBorder" Grid.Row="0"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Background="#0D0F0D"
                    BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel LastChildFill="False" VerticalAlignment="Stretch">

                    <!-- Logo -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="14,0,24,0">
                        <TextBlock Text="MACROENGINE"
                                   FontFamily="{StaticResource FontPrimary}"
                                   FontSize="20" FontWeight="Black"
                                   Foreground="#E8A020" VerticalAlignment="Bottom">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#E8A020" BlurRadius="18" ShadowDepth="0" Opacity="0.55"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text=" V2.0"
                                   FontFamily="{StaticResource FontMono}"
                                   FontSize="9" Foreground="#4A5A4A"
                                   VerticalAlignment="Bottom" Margin="6,0,0,2"/>
                </StackPanel>

                    <Rectangle DockPanel.Dock="Left" Width="1" Height="18" Fill="{StaticResource BorderLightBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>

                    <!-- Status dot + PRÊT -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,16,0">
                        <Ellipse Width="6" Height="6" Fill="#39D97A" Margin="0,0,6,0" VerticalAlignment="Center">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#39D97A" BlurRadius="8" ShadowDepth="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="PRÊT"
                                   FontFamily="{StaticResource FontMono}"
                                   FontSize="10" FontWeight="Medium"
                                   Foreground="#4A5A4A" VerticalAlignment="Center"/>
                </StackPanel>

                    <Rectangle DockPanel.Dock="Left" Width="1" Height="18" Fill="{StaticResource BorderLightBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>

                    <!-- Macro active (lié à la sélection) -->
                    <TextBlock x:Name="TitleBarActiveMacroText" DockPanel.Dock="Left"
                               Text="{Binding SelectedItem.Name, ElementName=MacrosListBox, FallbackValue='', TargetNullValue=''}"
                               FontFamily="{StaticResource FontMono}"
                               FontSize="10" FontWeight="Medium"
                               Foreground="#E8A020" VerticalAlignment="Center"/>

                    <!-- Window controls (right) -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="14,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="MinimizeButton" Style="{StaticResource WindowCaptionButtonStyle}" Width="40" Height="28"
                                Foreground="{StaticResource TextPrimaryBrush}" FontFamily="{StaticResource FontLucide}" FontSize="12"
                                Content="&#xE11C;" ToolTip="Réduire" Click="MinimizeButton_Click"/>
                        <Button x:Name="MaximizeButton" Style="{StaticResource WindowCaptionButtonStyle}" Width="40" Height="28"
                                Foreground="{StaticResource TextPrimaryBrush}" FontFamily="{StaticResource FontLucide}" FontSize="12"
                                Content="&#xE167;" ToolTip="Agrandir" Click="MaximizeButton_Click"/>
                        <Button x:Name="CloseButton" Style="{StaticResource WindowCaptionCloseButtonStyle}" Width="40" Height="28"
                                Foreground="{StaticResource TextPrimaryBrush}" FontFamily="{StaticResource FontLucide}" FontSize="12"
                                Content="&#xE1B2;" ToolTip="Fermer" Click="CloseButton_Click"/>
                </StackPanel>

                    <Rectangle DockPanel.Dock="Right" Width="1" Height="18" Fill="{StaticResource BorderLightBrush}" VerticalAlignment="Center"/>

                    <!-- Paramètres + Logs -->
                    <Button DockPanel.Dock="Right" Style="{StaticResource ButtonIcon}" Width="28" Height="28" Click="Settings_Click" ToolTip="Paramètres" Margin="0,0,8,0">
                        <TextBlock Text="&#xE30B;" FontFamily="{StaticResource FontLucide}" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Button>
                    <Button DockPanel.Dock="Right" Style="{StaticResource ButtonIcon}" Width="28" Height="28" Click="ShowLogs_Click" ToolTip="Journaux">
                        <TextBlock Text="&#xE085;" FontFamily="{StaticResource FontLucide}" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Button>

                    <Rectangle DockPanel.Dock="Right" Width="1" Height="18" Fill="{StaticResource BorderLightBrush}" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- ══════════════════════════════════════ SHELL (Rail | Workspace | Props) ══════════════════════════════════════ -->
            <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <!-- Sidebar gauche (largeur rail v2) -->
                <ColumnDefinition Width="200"/>
                <!-- Sans espace entre la colonne gauche et l'éditeur -->
                <ColumnDefinition Width="0"/>
                <!-- Zone centrale (éditeur) -->
                <ColumnDefinition Width="*"/>
                <!-- Colonnes réservées au mode panneau docké (désactivé: props en overlay) -->
                <ColumnDefinition Width="0"/>
                <ColumnDefinition Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════ RAIL (gauche) ═══════════════════════════ -->
            <Border x:Name="LeftColumnBorder" Grid.Column="0"
                    Background="#0D0F0D"
                    BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,1,0"
                    Padding="12,14,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- ＋ Nouvelle Macro (ambre, CTA v2, style clip-path approché) -->
                    <Button Grid.Row="0"
                            Style="{StaticResource ButtonSidebarPrimary}"
                            Click="NewMacro_Click"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,6"
                            Padding="9,9"
                            ToolTip="Nouvelle macro">
                        <Grid>
                            <!-- Corps du bouton -->
                            <Border Background="{x:Null}">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="＋"
                                               FontFamily="{StaticResource FontPrimary}"
                                               FontSize="15"
                                               FontWeight="ExtraBold"
                                               Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="NOUVELLE MACRO"
                                               FontFamily="{StaticResource FontPrimary}"
                                               FontSize="13"
                                               FontWeight="ExtraBold"
                                               VerticalAlignment="Center"
                                               TextOptions.TextFormattingMode="Display"
                                               TextOptions.TextRenderingMode="Aliased"/>
                        </StackPanel>
                            </Border>
                        </Grid>
                    </Button>

                    <!-- Import / Export (rail-btn style) -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource ButtonSidebarSecondary}"
                                Click="ImportMacro_Click" HorizontalAlignment="Stretch" Padding="6,5">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE0D7;" FontFamily="{StaticResource FontLucide}" Margin="0,0,4,0" VerticalAlignment="Center" FontSize="10"/>
                                <TextBlock Text="Import" VerticalAlignment="Center" FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource ButtonSidebarSecondary}"
                                Click="ExportMacro_Click" HorizontalAlignment="Stretch" Padding="6,5">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE19E;" FontFamily="{StaticResource FontLucide}" Margin="0,0,4,0" VerticalAlignment="Center" FontSize="10"/>
                                <TextBlock Text="Export" VerticalAlignment="Center" FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border Grid.Row="2" Height="1" Background="{StaticResource BorderMediumBrush}" Margin="0,0,0,8"/>

                    <!-- Section label MACROS — X -->
                    <TextBlock Grid.Row="3"
                               Text="{Binding ElementName=MacrosListBox, Path=Items.Count, StringFormat=MACROS — {0}}"
                               FontFamily="{StaticResource FontMono}"
                               FontSize="8" FontWeight="Bold"
                               Foreground="#4A5A4A"
                               Margin="14,8,14,4"/>

                    <!-- Liste des macros (scroll) -->
                    <Border Grid.Row="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False" Background="Transparent" Margin="0,0,0,8">
                            <ScrollViewer Style="{StaticResource ScrollViewerNoClipStyle}"
                                      VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,0,6,12"
                                          Background="Transparent">
                                    <ListBox x:Name="MacrosListBox"
                                             Style="{StaticResource MacrosListBoxStyle}"
                                             SelectionChanged="MacrosListBox_SelectionChanged"
                                             ItemContainerStyle="{StaticResource MacroListItemStyle}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel ClipToBounds="False"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid MaxHeight="48" ClipToBounds="False">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icône m-icon 26×26 (actif = bordure ambre + glow) -->
                                        <Border Grid.Column="0"
                                                Width="26" Height="26"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left"
                                                Margin="0,0,8,0"
                                                Background="{StaticResource BackgroundLevel4Brush}"
                                                BorderThickness="1"
                                                BorderBrush="{StaticResource BorderMediumBrush}"
                                                Visibility="{Binding IconType, Converter={StaticResource IconVisibilityConverter}}"
                                                ToolTip="{Binding IsEnabled, Converter={StaticResource MacroDisabledTooltipConverter}}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Opacity" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                            <Setter Property="Opacity" Value="0.4"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect Color="#33E8A020" BlurRadius="8" ShadowDepth="0" Opacity="1"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <TextBlock FontFamily="{StaticResource FontLucide}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                           Text="{Binding LucideIconCode, Converter={StaticResource LucideIconCharConverter}}"
                                                           Foreground="{Binding IconColor, Converter={StaticResource HexToBrushConverter}}"
                                                           Visibility="{Binding IconType, Converter={StaticResource IconTypeMatchConverter}, ConverterParameter=Lucide}"/>
                                                <Image Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                       Source="{Binding ProcessIconPath, Converter={StaticResource ProcessIconConverter}}"
                                                       Visibility="{Binding IconType, Converter={StaticResource IconTypeMatchConverter}, ConverterParameter=Process}"/>
                                            </Grid>
                                        </Border>

                                        <!-- Nom + raccourci empilés, alignés à gauche -->
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left"
                                                    Orientation="Vertical">
                                            <TextBlock Text="{Binding Name}"
                                                       FontFamily="{StaticResource FontPrimary}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       HorizontalAlignment="Left"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"/>
                                            <TextBlock Text="{Binding ShortcutKeyCode, Converter={StaticResource KeyCodeToNameConverter}}"
                                                       FontFamily="{StaticResource FontMono}"
                                                       FontSize="8"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Left"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,2,0,0"
                                                       Visibility="{Binding ShortcutKeyCode, Converter={StaticResource ShortcutVisibilityConverter}}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                        </Border>

                    <!-- Footer rail : ligne + bloc profil + Supprimer -->
                    <Border Grid.Row="5" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="6,8">
                        <StackPanel>
                            <Rectangle Height="1" Fill="{StaticResource BorderLightBrush}" Margin="0,0,0,8"/>
                            <Border Background="#111311" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                                    Padding="10,8" Margin="0,0,0,5">
                                <Grid>
                                        <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3"/>
                                        <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="#39D97A" VerticalAlignment="Stretch">
                                        <Rectangle.Effect>
                                            <DropShadowEffect Color="#39D97A" BlurRadius="6" ShadowDepth="0"/>
                                        </Rectangle.Effect>
                                    </Rectangle>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="PROFIL ACTIF" FontFamily="{StaticResource FontMono}" FontSize="8"
                                                   Foreground="#4A5A4A" Margin="0,0,0,2"/>
                                        <TextBlock x:Name="ActiveProfileText" Text="Par défaut"
                                                   FontFamily="{StaticResource FontPrimary}" FontSize="14" FontWeight="Bold"
                                                   Foreground="#C8D4C8"/>
                                    </StackPanel>
                                    <Button Grid.Column="3" Style="{StaticResource ButtonGhost}"
                                            Click="ManageProfiles_Click" Padding="4" ToolTip="Gérer les profils">
                                        <TextBlock Text="&#xE30B;" FontFamily="{StaticResource FontLucide}" FontSize="14" Foreground="#4A5A4A"/>
                                        </Button>
                                        </Grid>
                                    </Border>
                            <Button Style="{StaticResource ButtonGhostDanger}"
                                    Click="DeleteMacro_Click"
                                    HorizontalAlignment="Stretch"
                                    Padding="0,7">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="✕  SUPPRIMER" VerticalAlignment="Center"
                                               FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Bold"
                                               Foreground="#4A5A4A"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══════════════════════════ WORKSPACE (centre) ═══════════════════════════ -->
            <Border Grid.Column="2" BorderThickness="0,0,1,0" BorderBrush="{StaticResource BorderLightBrush}" Padding="0">
                <Grid>
                    <Grid.Background>
                        <DrawingBrush TileMode="Tile" Viewport="0,0,32,32" ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="#080A08">
                                        <GeometryDrawing.Geometry>
                                            <RectangleGeometry Rect="0,0,32,32"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Pen>
                                            <Pen Brush="#0D1A0D" Thickness="0.5"/>
                                        </GeometryDrawing.Pen>
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <LineGeometry StartPoint="32,0" EndPoint="32,32"/>
                                                <LineGeometry StartPoint="0,32" EndPoint="32,32"/>
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Grid.Background>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition x:Name="BottomPanelRow" Height="120"/>
                    </Grid.RowDefinitions>

                    <!-- ── BARRE D'ACTION (command bar) ── -->
                    <Border Grid.Row="0"
                            Background="#0D0F0D"
                            BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1"
                            UseLayoutRounding="True" SnapsToDevicePixels="True"
                            RenderOptions.ClearTypeHint="Enabled">
                        <DockPanel LastChildFill="False" UseLayoutRounding="True">
                            <!-- Droite : STOP, ENREG., PROPS -->
                            <Border DockPanel.Dock="Right"
                                    BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton x:Name="MacroEnableToggle"
                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                  Checked="MacroEnableToggle_Checked"
                                                  Unchecked="MacroEnableToggle_Unchecked"
                                                  IsEnabled="False"
                                                  VerticalAlignment="Center"
                                                  Margin="12,0,10,0"
                                                  ToolTip="Activer / désactiver la macro"/>
                                    <Border Width="1" Height="24" Background="{StaticResource BorderLightBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Style="{StaticResource ActionCard}" Padding="14,6,14,8" Click="StopMacro_Click">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="■" FontSize="14" Foreground="#E84040" HorizontalAlignment="Center"/>
                                            <TextBlock Text="STOP" FontFamily="{StaticResource FontPrimary}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="#4A5A4A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Padding="14,6,14,8" Cursor="Hand"
                                            Background="#E8A020" BorderBrush="Transparent" BorderThickness="0"
                                            Click="StartMacro_Click">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="●" FontSize="14" Foreground="#0A0800" HorizontalAlignment="Center"/>
                                            <TextBlock Text="ENREG." FontFamily="{StaticResource FontPrimary}"
                                                       FontSize="10" FontWeight="Black"
                                                       Foreground="#0A0800" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="PropsToggleButton" Style="{StaticResource ActionCard}" Padding="14,6,14,8" Click="PropsToggleButton_Click">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="⚙" FontSize="14" Foreground="#E8A020" HorizontalAlignment="Center"/>
                                            <TextBlock Text="PROPS" FontFamily="{StaticResource FontPrimary}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="#4A5A4A" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                            <!-- Gauche : AJOUTER UNE ACTION + OUTILS -->
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <Border BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,1,0">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top"
                                                   Style="{StaticResource ToolbarSectionLabelStyle}"
                                                   Text="AJOUTER UNE ACTION"
                                                   Margin="10,4,10,0"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource ActionCard}" Click="QuickAddAction_Click" Tag="keyboard">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Border Width="22" Height="22" CornerRadius="4"
                                                            Background="#1234C8B8" HorizontalAlignment="Center">
                                                        <TextBlock Text="⌨" FontSize="12" Foreground="#34C8B8"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="TOUCHE" FontFamily="{StaticResource FontPrimary}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="#7A927A" HorizontalAlignment="Center"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource ActionCard}" Click="QuickAddAction_Click" Tag="mouse">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Border Width="22" Height="22" CornerRadius="4"
                                                            Background="#1234C8B8" HorizontalAlignment="Center">
                                                        <TextBlock Text="&#xE28E;" FontFamily="{StaticResource FontLucide}" FontSize="12" Foreground="#34C8B8"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="CLIC" FontFamily="{StaticResource FontPrimary}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="#7A927A" HorizontalAlignment="Center"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Button>
                                            <Rectangle Width="1" Height="24" Fill="{StaticResource BorderLightBrush}" VerticalAlignment="Center" Margin="2,0"/>
                                            <Button Style="{StaticResource ActionCard}" Click="QuickAddAction_Click" Tag="text">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Border Width="22" Height="22" CornerRadius="4"
                                                            Background="#1C201C" HorizontalAlignment="Center">
                                                        <TextBlock Text="&#xE0CC;" FontFamily="{StaticResource FontLucide}" FontSize="12"
                                                                   Foreground="#4A5A4A"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="TEXTE" FontFamily="{StaticResource FontPrimary}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="#7A927A" HorizontalAlignment="Center"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource ActionCard}" Click="QuickAddAction_Click" Tag="delay">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Border Width="22" Height="22" CornerRadius="4"
                                                            Background="#1AE8A020" HorizontalAlignment="Center">
                                                        <TextBlock Text="&#xE1E0;" FontFamily="{StaticResource FontLucide}" FontSize="12" Foreground="#E8A020"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="DÉLAI" FontFamily="{StaticResource FontPrimary}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="#7A927A" HorizontalAlignment="Center"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Button>
                                            <Rectangle Width="1" Height="24" Fill="{StaticResource BorderLightBrush}" VerticalAlignment="Center" Margin="2,0"/>
                                            <Button Style="{StaticResource ActionCard}" Click="QuickAddAction_Click" Tag="variable">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Border Width="22" Height="22" CornerRadius="4"
                                                            Background="#15A78BFA" HorizontalAlignment="Center">
                                                        <TextBlock Text="&#xE36A;" FontFamily="{StaticResource FontLucide}" FontSize="12"
                                                                   Foreground="#A78BFA"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="VARIABLE" FontFamily="{StaticResource FontPrimary}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="#7A927A" HorizontalAlignment="Center"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource ActionCard}" Click="QuickAddAction_Click" Tag="condition">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Border Width="22" Height="22" CornerRadius="4"
                                                            Background="#15E84040" HorizontalAlignment="Center">
                                                        <TextBlock Text="&#xE440;" FontFamily="{StaticResource FontLucide}" FontSize="12"
                                                                   Foreground="#E84040"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="CONDITION" FontFamily="{StaticResource FontPrimary}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="#7A927A" HorizontalAlignment="Center"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource ActionCard}" Click="QuickAddAction_Click" Tag="repeat">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Border Width="22" Height="22" CornerRadius="4"
                                                            Background="#1239D97A" HorizontalAlignment="Center">
                                                        <TextBlock Text="&#xE411;" FontFamily="{StaticResource FontLucide}" FontSize="12"
                                                                   Foreground="#39D97A"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="RÉPÉTER" FontFamily="{StaticResource FontPrimary}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="#7A927A" HorizontalAlignment="Center"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                                <Border BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,1,0">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top"
                                                   Style="{StaticResource ToolbarSectionLabelStyle}"
                                                   Text="OUTILS"
                                                   Margin="10,4,10,0"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource ActionCard}" Click="QuickAddAction_Click" Tag="presets">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Border Width="22" Height="22" CornerRadius="4"
                                                            Background="#1C201C" HorizontalAlignment="Center">
                                                        <TextBlock Text="&#xE470;" FontFamily="{StaticResource FontLucide}" FontSize="12" Foreground="#4A5A4A"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="PRESETS" FontFamily="{StaticResource FontPrimary}"
                                                               FontSize="10" FontWeight="Bold" Foreground="#7A927A"
                                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Button>
                                            <Rectangle Width="1" Height="24" Fill="{StaticResource BorderLightBrush}" VerticalAlignment="Center" Margin="2,0"/>
                                            <Button Style="{StaticResource ActionCard}" Click="QuickAddAction_Click" Tag="undo">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Border Width="22" Height="22" CornerRadius="4"
                                                            Background="#1C201C" HorizontalAlignment="Center">
                                                        <TextBlock Text="&#xE148;" FontFamily="{StaticResource FontLucide}" FontSize="12" Foreground="#4A5A4A"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="ANNULER" FontFamily="{StaticResource FontPrimary}"
                                                               FontSize="10" FontWeight="Bold" Foreground="#7A927A"
                                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource ActionCard}" Click="QuickAddAction_Click" Tag="redo">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Border Width="22" Height="22" CornerRadius="4"
                                                            Background="#1C201C" HorizontalAlignment="Center">
                                                        <TextBlock Text="&#xE149;" FontFamily="{StaticResource FontLucide}" FontSize="12" Foreground="#4A5A4A"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="REFAIRE" FontFamily="{StaticResource FontPrimary}"
                                                               FontSize="10" FontWeight="Bold" Foreground="#7A927A"
                                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                                <Border BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,1,0">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top"
                                                   Style="{StaticResource ToolbarSectionLabelStyle}"
                                                   Text="EXECUTION"
                                                   Margin="8,4,8,0"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource ActionCard}" Padding="6,5,6,6" MinWidth="48"
                                                    Click="ExecuteMacro_Click"
                                                    ToolTip="Exécuter la macro sélectionnée (bouton ou raccourci de la macro)">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <!-- * | icône | gap | raccourci | * -->
                                                    <Grid Width="70" HorizontalAlignment="Center">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="22"/>
                                                            <ColumnDefinition Width="3"/>
                                                            <ColumnDefinition Width="32"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="4"
                                                                Background="#1239D97A" VerticalAlignment="Center">
                                                            <TextBlock Text="&#xE13C;" FontFamily="{StaticResource FontLucide}" FontSize="12" Foreground="#39D97A"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock x:Name="ExecuteMacroShortcutHintText"
                                                                   Grid.Column="3"
                                                                   Style="{StaticResource ToolbarShortcutHintStyle}"
                                                                   Visibility="Collapsed"/>
                                                    </Grid>
                                                    <TextBlock Text="LANCER" FontFamily="{StaticResource FontPrimary}"
                                                               FontSize="10" FontWeight="Bold" Foreground="#7A927A"
                                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource ActionCard}" Padding="6,5,6,6" MinWidth="48"
                                                    Click="StepMacro_Click"
                                                    ToolTip="Exécuter une seule action à chaque clic">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Grid Width="70" HorizontalAlignment="Center">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="22"/>
                                                            <ColumnDefinition Width="3"/>
                                                            <ColumnDefinition Width="32"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="4"
                                                                Background="#1AE8A020" VerticalAlignment="Center">
                                                            <TextBlock Text="&#xE3EA;" FontFamily="{StaticResource FontLucide}" FontSize="12" Foreground="#E8A020"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="3"
                                                                   Style="{StaticResource ToolbarShortcutHintStyle}"
                                                                   Text="Clic"/>
                                                    </Grid>
                                                    <TextBlock Text="PAS À PAS" FontFamily="{StaticResource FontPrimary}"
                                                               FontSize="10" FontWeight="Bold" Foreground="#7A927A"
                                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource ActionCard}" Padding="6,5,6,6" MinWidth="48"
                                                    Click="StopMacro_Click"
                                                    ToolTip="Arrêter l'exécution ou l'enregistrement">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Grid Width="70" HorizontalAlignment="Center">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="22"/>
                                                            <ColumnDefinition Width="3"/>
                                                            <ColumnDefinition Width="32"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="4"
                                                                Background="#15E84040" VerticalAlignment="Center">
                                                            <TextBlock Text="&#xE167;" FontFamily="{StaticResource FontLucide}" FontSize="12" Foreground="#E84040"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock x:Name="StopGlobalShortcutHintText"
                                                                   Grid.Column="3"
                                                                   Style="{StaticResource ToolbarShortcutHintStyle}"/>
                                                    </Grid>
                                                    <TextBlock Text="ARRÊTER" FontFamily="{StaticResource FontPrimary}"
                                                               FontSize="10" FontWeight="Bold" Foreground="#7A927A"
                                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Zone éditeur (TimelineEditor) -->
                    <ContentControl x:Name="MacroEditorContainer" Grid.Row="1" Margin="8"/>
                    <!-- Barre du bas (bottombar) -->
                    <Border Grid.Row="2" Background="#0D0F0D" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="320"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Historique (log-panel) -->
                        <Border x:Name="ActionsPanelBorder" Grid.Column="0" 
                                Background="#0D0F0D"
                                BorderThickness="0,1,1,0"
                                BorderBrush="{StaticResource BorderLightBrush}"
                                Padding="16,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="HISTORIQUE" 
                                               FontFamily="{StaticResource FontMono}"
                                               FontSize="8" FontWeight="Bold"
                                               Foreground="#4A5A4A"
                                               VerticalAlignment="Center"/>
                                    <Border Margin="8,0,0,0" Padding="6,1" 
                                            Background="#111311"
                                            BorderBrush="{StaticResource BorderLightBrush}"
                                            BorderThickness="1">
                                    <TextBlock x:Name="ActionsCountText" 
                                                   Text="0" 
                                                   FontFamily="{StaticResource FontMono}"
                                                   FontSize="9"
                                                   Foreground="#E8A020"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <Button Content="Effacer" 
                                            x:Name="ClearActionsButton" 
                                            Style="{StaticResource ButtonGhost}"
                                            Click="ClearActionsButton_Click" 
                                            Padding="4,0"
                                            Margin="8,0,0,0"
                                            FontSize="9"
                                            FontFamily="{StaticResource FontMono}"/>
                                </StackPanel>
                                <ListBox x:Name="ActionsListBox" 
                                         Grid.Row="1"
                                         SelectionMode="Single"
                                         Background="Transparent"
                                         BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                <TextBlock Text="{Binding Timestamp}" 
                                                           Style="{StaticResource TextMuted}"
                                                           Width="70"/>
                                                <TextBlock Text="{Binding Description}" 
                                                           Style="{StaticResource TextSecondary}"
                                                           Margin="8,0,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                        
                        <!-- Zone de test (test-panel) -->
                        <Border x:Name="TestPanelBorder" Grid.Column="1"
                                Background="#0D0F0D"
                                BorderThickness="0"
                                Padding="0,10,14,10">
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="{StaticResource BorderLightBrush}" Margin="0,0,14,0"/>
                                <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" 
                                               Text="ZONE DE TEST" 
                                               FontFamily="{StaticResource FontMono}"
                                               FontSize="8" FontWeight="Bold"
                                               Foreground="#4A5A4A"
                                               Margin="0,0,0,6"/>
                                <TextBox x:Name="TestTextBox" 
                                         Grid.Row="1"
                                             Background="#111311"
                                             Foreground="#7A927A"
                                             BorderBrush="{StaticResource BorderLightBrush}"
                                             BorderThickness="1"
                                             FontFamily="{StaticResource FontMono}"
                                             FontSize="11"
                                             Padding="10,8"
                                         AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             CaretBrush="#E8A020"
                                         VerticalScrollBarVisibility="Auto"
                                             Text="Tapez ici pour tester vos macros…"
                                         GotFocus="TestTextBox_GotFocus"/>
                                </Grid>
                            </Grid>
                            </Border>
                    </Grid>
                        </Border>
                </Grid>
            </Border>

            <!-- ═══════════════════════════ PANNEAU PROPRIÉTÉS ═══════════════════════════ -->
            <Border x:Name="PropsPanelBorder"
                    Grid.Column="2"
                    Panel.ZIndex="20"
                    HorizontalAlignment="Right"
                    Width="320" MinWidth="320" MaxWidth="320"
                    Background="#0D0F0D"
                    BorderThickness="2,0,0,0"
                    BorderBrush="#E8A020"
                    Padding="8"
                    DataContext="{Binding SelectedItem, ElementName=MacrosListBox}">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="PropsPanelTranslate" X="336"/>
                </Border.RenderTransform>
                <StackPanel HorizontalAlignment="Stretch">
                        <!-- Titre -->
                        <DockPanel Margin="0,0,0,10" LastChildFill="False">
                            <TextBlock Text="Propriétés"
                                       Style="{StaticResource TextSubheading}"
                                       VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right"
                                    Width="18" Height="18"
                                    Padding="0"
                                    Cursor="Hand"
                                    Style="{StaticResource ButtonGhost}"
                                    ToolTip="Fermer"
                                    Click="PropsToggleButton_Click">
                                <TextBlock Text="✕"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>
                        </DockPanel>

                        <!-- Nom de la macro -->
                        <TextBlock Text="Nom" Style="{StaticResource TextLabel}"/>
                        <Border Style="{StaticResource PanelPropertiesFieldElevation}">
                            <Border Style="{StaticResource PanelPropertiesField}"
                                    Padding="6,4">
                                <TextBox x:Name="MacroNameTextBox"
                                     Style="{StaticResource TextBoxPropertiesFieldCentered}"
                                     Padding="0"
                                     TextChanged="MacroNameTextBox_TextChanged"
                                     TextAlignment="Left"
                                     VerticalContentAlignment="Center"
                                     CaretBrush="White"
                                     Cursor="IBeam"/>
                            </Border>
                        </Border>

                        <!-- Description -->
                        <TextBlock Text="Description" Style="{StaticResource TextLabel}"/>
                        <Border Style="{StaticResource PanelPropertiesFieldElevation}">
                            <Border Style="{StaticResource PanelPropertiesField}"
                                    Padding="6,4">
                                <TextBox x:Name="MacroDescriptionTextBox"
                                     Style="{StaticResource TextBoxPropertiesField}"
                                     Padding="0"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Height="60"
                                     TextChanged="MacroDescriptionTextBox_TextChanged"
                                     TextAlignment="Left"
                                     VerticalContentAlignment="Top"
                                     CaretBrush="White"
                                     Cursor="IBeam"
                                     PreviewMouseDown="MacroDescriptionTextBox_PreviewMouseDown"/>
                            </Border>
                        </Border>

                        <!-- Icône (processus uniquement) -->
                        <StackPanel Margin="0,12,0,10">
                            <ComboBox x:Name="IconTypeComboBox"
                                      Style="{StaticResource ComboBoxModern}"
                                      Width="220"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,0,0,8"
                                      Visibility="Collapsed"
                                      SelectionChanged="IconTypeComboBox_SelectionChanged"/>
                            <StackPanel x:Name="IconLucidePanel" Visibility="Collapsed" Margin="0,0,0,8">
                                <TextBlock Text="Icône Lucide" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                                <Border Style="{StaticResource PanelChipsContainer}" Padding="8,6">
                                    <ListBox x:Name="LucideIconsListBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             MaxHeight="200"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             SelectionChanged="LucideIconListBox_SelectionChanged">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="2"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="Bd" Width="32" Height="32" CornerRadius="4"
                                                                    Background="Transparent" BorderBrush="Transparent" BorderThickness="1"
                                                                    Cursor="Hand">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF"/>
                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#25FFFFFF"/>
                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Code, Converter={StaticResource LucideIconCharConverter}}"
                                                           FontFamily="{StaticResource FontLucide}"
                                                           FontSize="16"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           ToolTip="{Binding Label}"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </StackPanel>
                            <StackPanel x:Name="IconColorPanel" Visibility="Collapsed" Margin="0,0,0,8">
                                <TextBlock Text="Couleur" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                                <Border Style="{StaticResource PanelChipsContainer}" Padding="8,6">
                                    <ListBox x:Name="IconColorListBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             SelectionChanged="IconColorListBox_SelectionChanged">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="4,2"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="Bd" Width="28" Height="28" CornerRadius="14"
                                                                    Background="Transparent" BorderBrush="Transparent" BorderThickness="1"
                                                                    Cursor="Hand">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
                                                                    <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Ellipse Width="20" Height="20"
                                                         Fill="{Binding Code, Converter={StaticResource HexToBrushConverter}}"
                                                         ToolTip="{Binding Label}"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </StackPanel>
                            <StackPanel x:Name="IconProcessPanel" Visibility="Collapsed" Margin="0,0,0,0">
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Icône" Style="{StaticResource TextLabel}" VerticalAlignment="Center"/>
                                    <Button x:Name="AddProcessIconButton" Grid.Column="1"
                                            Content="+ Icône"
                                            Style="{StaticResource ButtonPropertiesAction}"
                                            Click="AddProcessIcon_Click"
                                            Padding="8,4" MinWidth="72"/>
                                </Grid>
                                <Border Style="{StaticResource PanelChipsContainer}" Padding="4,4">
                                    <ListBox x:Name="ProcessIconsListBox"
                                            Style="{StaticResource ListBoxNoScrollBarStyle}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            MaxHeight="102"
                                            SelectionChanged="ProcessIconsListBox_SelectionChanged">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="1"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="Bd" Width="32" Height="32" CornerRadius="4"
                                                                    Background="Transparent" BorderBrush="Transparent" BorderThickness="1"
                                                                    Cursor="Hand">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF"/>
                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#25FFFFFF"/>
                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Image Width="20" Height="20"
                                                       Source="{Binding Path, Converter={StaticResource ProcessIconConverter}}"
                                                       Stretch="Uniform"
                                                       ToolTip="{Binding DisplayName}"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Border Style="{StaticResource SeparatorHorizontal}" Margin="0,12,0,12"/>

                        <!-- Raccourci clavier -->
                        <StackPanel Margin="0,0,0,10">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Raccourci clavier" Style="{StaticResource TextLabel}" VerticalAlignment="Center" Margin="0"/>
                                <Button Grid.Column="1"
                                    Content="Définir"
                                    Style="{StaticResource ButtonPropertiesAction}"
                                    Click="SetShortcut_Click"
                                    MinWidth="72"/>
                            </Grid>
                            <Border x:Name="ShortcutDisplayBorder"
                                    Style="{StaticResource PanelChipsContainer}"
                                    Padding="10,8"
                                    MinHeight="32"
                                    MaxHeight="32">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="ShortcutDisplayText" 
                                               Grid.Column="0"
                                               Text="Non défini"
                                               Style="{StaticResource TextMono}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            x:Name="ClearShortcutButton"
                                            Padding="4,0"
                                            MinWidth="24"
                                            MinHeight="24"
                                            VerticalAlignment="Center"
                                            Cursor="Hand"
                                            ToolTip="Retirer le raccourci"
                                            Visibility="{Binding ShortcutKeyCode, Converter={StaticResource ShortcutVisibilityConverter}}"
                                            Click="ClearShortcut_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <TextBlock x:Name="ClearIcon"
                                                                       Text="&#xE1B2;"
                                                                       FontFamily="{StaticResource FontLucide}"
                                                                       FontSize="12"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ClearIcon" Property="Foreground"
                                                                            Value="{StaticResource TextPrimaryBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Opacity" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}"
                                                                 Value="True">
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Applications cibles -->
                        <StackPanel Margin="0,0,0,10">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Applications cibles" Style="{StaticResource TextLabel}" VerticalAlignment="Center" Margin="0"/>
                                <Button x:Name="SelectAppsButton"
                                        Grid.Column="1"
                                        Content="Sélectionner"
                                        Style="{StaticResource ButtonPropertiesAction}"
                                        Click="SelectApps_Click"
                                        MinWidth="88"
                                        VerticalAlignment="Center"/>
                            </Grid>
                            <Border Style="{StaticResource PanelChipsContainer}"
                                    Padding="10,8"
                                    MinHeight="36"
                                    MaxHeight="160">
                                <ScrollViewer Style="{StaticResource ScrollViewerNoClipStyle}"
                                          MaxHeight="140"
                                          Padding="0">
                                <WrapPanel x:Name="TargetAppsPanel">
                                    <TextBlock x:Name="NoAppsText" 
                                               Text="Toutes les applications" 
                                               Style="{StaticResource TextMuted}"/>
                                </WrapPanel>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>

                        <!-- Mode de déclenchement (conditions If) -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Mode de déclenchement" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="TriggerModeComboBox"
                                      Style="{StaticResource ComboBoxModern}"
                                      Width="220"
                                      HorizontalAlignment="Left"
                                      ItemContainerStyle="{StaticResource TriggerModeComboBoxItemStyle}"
                                      SelectionChanged="TriggerModeComboBox_SelectionChanged"/>
                            <StackPanel x:Name="TriggerModeOptionsPanel" Visibility="Collapsed" Margin="0,8,0,0">
                                <TextBlock Text="Intervalle (ms)" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                                <TextBox x:Name="ContinuousMonitoringIntervalTextBox"
                                         Style="{StaticResource TextBoxModern}"
                                         Width="54"
                                         Padding="3,2"
                                         HorizontalAlignment="Left"
                                         Text="200"
                                         PreviewMouseDown="MacroDescriptionTextBox_PreviewMouseDown"
                                         TextChanged="ContinuousMonitoringInterval_TextChanged"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Style="{StaticResource SeparatorHorizontal}"/>

                        <!-- État du moteur -->
                        <TextBlock Text="État" Style="{StaticResource TextLabel}" Margin="0,8,0,0"/>
                        <Border Style="{StaticResource PanelChipsContainer}"
                                Padding="12,8"
                                Margin="0,0,0,12">
                            <TextBlock x:Name="EngineStateText" 
                                           Text="Prêt" 
                                           Foreground="{StaticResource SuccessBrush}"
                                           FontWeight="Medium"/>
                        </Border>

                        <!-- Application active -->
                        <TextBlock Text="Application active" Style="{StaticResource TextLabel}"/>
                        <Border Style="{StaticResource PanelChipsContainer}"
                                Padding="12,8">
                            <TextBlock x:Name="ActiveAppText" 
                                       Text="Aucune" 
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>
                </StackPanel>
            </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════════════
                 STATUSBAR - Barre de statut
                 ══════════════════════════════════════════════════════════════════ -->
            <!-- Barre de statut retirée ; StatusText/TimeText gardés masqués pour le code-behind -->
            <Grid Grid.Row="2" Visibility="Collapsed" Height="0">
                <TextBlock x:Name="StatusText" Text="Prêt"/>
                <TextBlock x:Name="TimeText" Text="00:00:00"/>
                </Grid>
        </Grid>
    </Border>
</Window>

