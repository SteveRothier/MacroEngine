<Window x:Class="MacroEngine.UI.PixelColorPopoverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize"
        Background="Transparent" AllowsTransparency="True"
        ShowInTaskbar="False"
        Title="Pixel couleur">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MacroEngine;component/Themes/Colors.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MacroEngine;component/Themes/Typography.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MacroEngine;component/Themes/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- rgba(232,64,64,0.06) -->
            <SolidColorBrush x:Key="PpPipetteHoverBgBrush" Color="#E84040" Opacity="0.06"/>
            <Style x:Key="PpPipetteBtnStyle" TargetType="Border">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="0,7"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
                        <Setter Property="Background" Value="{StaticResource PpPipetteHoverBgBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Canvas x:Name="OverlayGrid" Background="#01000000"
            PreviewMouseDown="OverlayGrid_PreviewMouseDown">
        <Border x:Name="ContentContainer">
            <!-- .pixel-pop -->
            <Border x:Name="RootBorder" Width="260"
                    Background="{StaticResource BackgroundSecondaryBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.8" BlurRadius="40" ShadowDepth="16"/>
                </Border.Effect>
                <StackPanel>
                    <!-- pp-body -->
                    <StackPanel x:Name="PpBody" Margin="12,10" VerticalAlignment="Top">
                        <!-- Pipette icon + Swatch + Hex + X/Y -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                                    <Border x:Name="PipetteIconBtn" Width="28" Height="28"
                                            Style="{StaticResource PpPipetteBtnStyle}"
                                            MouseLeftButtonDown="PipetteIconBtn_MouseLeftButtonDown"/>
                                    <Border Width="6"/>
                                    <Border x:Name="SwatchBorder" Width="56" Height="56"
                                            CornerRadius="28"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="SwatchBorder_MouseLeftButtonDown"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Top">
                                <TextBlock Text="HEX" FontSize="8" FontWeight="Bold"
                                           FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                <TextBox x:Name="HexInput" MaxLength="7" Margin="0,0,0,6"
                                         FontSize="11" MinHeight="24" Padding="4,7"
                                         VerticalContentAlignment="Center"
                                         Style="{StaticResource TextBoxNoCornerRadiusKeepBorder}"
                                         Background="{StaticResource BackgroundPrimaryBrush}"
                                         Foreground="{StaticResource TextSecondaryBrush}"
                                         BorderBrush="{StaticResource BorderLightBrush}"
                                         FontFamily="{StaticResource FontMono}"
                                         LostFocus="HexInput_LostFocus"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="X" FontSize="8" FontWeight="Bold"
                                                   FontFamily="{StaticResource FontMono}"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                        <TextBox x:Name="XInput" FontSize="11" MinHeight="24" Padding="4,7"
                                                 Style="{StaticResource TextBoxNoCornerRadiusKeepBorder}"
                                                 Background="{StaticResource BackgroundPrimaryBrush}"
                                                 Foreground="{StaticResource TextSecondaryBrush}"
                                                 BorderBrush="{StaticResource BorderLightBrush}"
                                                 FontFamily="{StaticResource FontMono}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Y" FontSize="8" FontWeight="Bold"
                                                   FontFamily="{StaticResource FontMono}"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                        <TextBox x:Name="YInput" FontSize="11" MinHeight="24" Padding="4,7"
                                                 Style="{StaticResource TextBoxNoCornerRadiusKeepBorder}"
                                                 Background="{StaticResource BackgroundPrimaryBrush}"
                                                 Foreground="{StaticResource TextSecondaryBrush}"
                                                 BorderBrush="{StaticResource BorderLightBrush}"
                                                 FontFamily="{StaticResource FontMono}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                        <!-- Tolérance + Mode -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Tolérance (%)" FontSize="8" FontWeight="Bold"
                                           FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                <TextBox x:Name="ToleranceInput" FontSize="11" MinHeight="24" Padding="4,7"
                                         Style="{StaticResource TextBoxNoCornerRadiusKeepBorder}"
                                         Background="{StaticResource BackgroundPrimaryBrush}"
                                         Foreground="{StaticResource TextSecondaryBrush}"
                                         BorderBrush="{StaticResource BorderLightBrush}"
                                         FontFamily="{StaticResource FontMono}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Mode" FontSize="8" FontWeight="Bold"
                                           FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                <ComboBox x:Name="ModeCombo" FontSize="11" MinHeight="24" Padding="4,7"
                                          Style="{StaticResource ComboBoxModern}"
                                          Background="{StaticResource BackgroundPrimaryBrush}"
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          BorderBrush="{StaticResource BorderLightBrush}"
                                          FontFamily="{StaticResource FontMono}">
                                    <ComboBoxItem Content="RGB"/>
                                    <ComboBoxItem Content="HSV"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Canvas>
</Window>
