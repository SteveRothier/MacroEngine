<UserControl x:Class="MacroEngine.UI.TimelineEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="600">

    <!-- Barre d’ajout d’actions retirée : tout passe par la barre du haut (MainWindow). -->

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════
             TIMELINE - Liste verticale des actions
             ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="Transparent"
                CornerRadius="12"
                ClipToBounds="True">

            <ScrollViewer x:Name="TimelineScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="12"
                          IsDeferredScrollingEnabled="True">
                <StackPanel x:Name="TimelineStackPanel"
                           Orientation="Vertical"
                           HorizontalAlignment="Stretch"
                           UseLayoutRounding="True">

                    <StackPanel x:Name="EmptyStatePanel"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Visibility="Visible"
                                Margin="0,100,0,0">
                        <TextBlock Text="&#xE0AC;"
                                   FontFamily="{StaticResource FontLucide}"
                                   FontSize="48"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>
                        <TextBlock Text="Aucune action dans cette macro"
                                   Style="{StaticResource TextHeading}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Utilisez la barre du haut pour ajouter des actions"
                                   Style="{StaticResource TextMuted}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Contrôles fantômes : MainWindow branche Enreg./Stop dessus ; état Annuler/Refaire conservé. -->
        <StackPanel Grid.Row="0"
                    Visibility="Collapsed"
                    Width="0" Height="0"
                    IsHitTestVisible="False">
            <ScrollViewer x:Name="ToolbarScrollViewer" Width="1" Height="1"/>
            <Ellipse x:Name="RecordDotAnim" Width="0" Height="0" Opacity="0"/>
            <Button x:Name="RecordButton" Width="0" Height="0"/>
            <Button x:Name="StopButton" Width="0" Height="0"/>
            <Button x:Name="UndoButton" Click="UndoButton_Click" Width="0" Height="0"/>
            <Button x:Name="RedoButton" Click="RedoButton_Click" Width="0" Height="0"/>
        </StackPanel>
    </Grid>
</UserControl>
