<Window x:Class="MacroEngine.UI.ZonePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aperçu zone"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#40000000"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Cursor="Arrow">
    <Canvas x:Name="PreviewCanvas" Background="Transparent" MouseLeftButtonDown="PreviewCanvas_MouseLeftButtonDown">
        <Rectangle x:Name="PreviewRect"
                   Stroke="#E84040"
                   StrokeThickness="2"
                   Fill="#19E84040"
                   Visibility="Visible"/>
        <Border x:Name="LabelBorder"
                Background="#0D0F0D"
                BorderBrush="#E84040"
                BorderThickness="1"
                CornerRadius="0"
                Padding="8,5">
            <TextBlock x:Name="LabelText"
                       Foreground="#E84040"
                       FontSize="11"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Border>
    </Canvas>
</Window>
