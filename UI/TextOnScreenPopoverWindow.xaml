<Window x:Class="MacroEngine.UI.TextOnScreenPopoverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Texte à l'écran"
        WindowStyle="None" ResizeMode="NoResize"
        Background="Transparent" AllowsTransparency="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MacroEngine;component/Themes/Colors.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MacroEngine;component/Themes/Typography.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MacroEngine;component/Themes/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Bouton icône sans background (transparent au hover/press) -->
            <Style x:Key="IconButtonTransparentStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Nouveau "type" de TextBox OCR (template 100% contrôlé).
                 Objectif: éliminer toute réserve de largeur (gouttière) à droite. -->
            <Style x:Key="TextBoxOcrCompactActiveRedStyle" TargetType="TextBox">
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="CaretBrush" Value="{StaticResource ErrorBrush}"/>
                <Setter Property="Cursor" Value="IBeam"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="0"
                                    Padding="0">
                                <!-- Le padding ne doit passer que via Margin du contenu -->
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Foreground="{TemplateBinding Foreground}"
                                              Style="{StaticResource ScrollViewerNoClipStyle}"
                                              Margin="0"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Hidden"
                                              CanContentScroll="False"
                                              PanningMode="None"
                                              Focusable="False"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Canvas x:Name="OverlayGrid"
            Background="#01000000"
            PreviewMouseDown="OverlayGrid_PreviewMouseDown">
        <Border x:Name="ContentContainer">
            <Border x:Name="RootBorder"
                    Width="280"
                    Height="180"
                    Background="{StaticResource BackgroundSecondaryBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.8" BlurRadius="40" ShadowDepth="16"/>
                </Border.Effect>

                <StackPanel>
                    <StackPanel Margin="12,0" VerticalAlignment="Top">
                        <!-- Texte -->
                        <TextBlock Text="Texte à rechercher"
                                   FontSize="9" FontWeight="Bold"
                                   FontFamily="{StaticResource FontMono}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,4,0,6"/>
                        <TextBox x:Name="TextInputBox"
                                 Style="{StaticResource TextBoxOcrCompactActiveRedStyle}"
                                 Background="{StaticResource BackgroundPrimaryBrush}"
                                 Foreground="{StaticResource TextSecondaryBrush}"
                                 BorderBrush="{StaticResource BorderLightBrush}"
                                 FontFamily="{StaticResource FontMono}"
                                 FontSize="11"
                                Padding="2,3,2,3"
                                 ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                 MinHeight="72"
                                 MaxHeight="140"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 GotKeyboardFocus="TextInputBox_GotKeyboardFocus"
                                 LostKeyboardFocus="TextInputBox_LostKeyboardFocus"/>

                        <!-- Zone -->
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Margin="0" FontSize="10" FontWeight="Bold"
                                       FontFamily="{StaticResource FontMono}"
                                       Foreground="{StaticResource TextMutedBrush}">
                                Zone de recherche (optionnel)
                            </TextBlock>

                            <Grid Grid.Row="1" Margin="0,0,0,0" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="ZoneInfoText"
                                           Grid.Column="0"
                                           FontSize="9"
                                           FontFamily="{StaticResource FontMono}"
                                           FontStyle="Italic"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"
                                           Cursor="Arrow"
                                           ToolTip="Cliquer pour visualiser / définir la zone"
                                           VerticalAlignment="Center"
                                           MouseEnter="ZoneInfoText_MouseEnter"
                                           MouseLeave="ZoneInfoText_MouseLeave"/>

                                <Button x:Name="ZonePickButton"
                                        Grid.Column="1"
                                        Width="34" Height="26"
                                        Cursor="Hand"
                                        Margin="10,0,0,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="ZonePickButton_Click"
                                        MouseEnter="ZonePickButton_MouseEnter"
                                        MouseLeave="ZonePickButton_MouseLeave"
                                        Style="{StaticResource IconButtonTransparentStyle}">
                                    <TextBlock x:Name="ZonePickIcon"
                                               Text="&#xE509;"
                                               FontSize="14"
                                               FontFamily="{StaticResource FontLucide}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,-1,0,0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Button>
                            </Grid>
                        </Grid>

                    </StackPanel>

                    <!-- Note OCR supprimée (comme demandé) -->
                </StackPanel>
            </Border>
        </Border>
    </Canvas>
</Window>

