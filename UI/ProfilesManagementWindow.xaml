<Window x:Class="MacroEngine.UI.ProfilesManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Gérer les Profils"
        Width="900"
        Height="580"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        MinWidth="720" MinHeight="460"
        Background="{StaticResource BackgroundPrimaryBrush}">
    <Border x:Name="RootBorder"
            Background="{StaticResource BackgroundPrimaryBrush}"
            BorderBrush="{StaticResource BorderLightBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barre de titre -->
            <Border x:Name="TitleBarBorder" Grid.Row="0"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Background="{StaticResource BackgroundSecondaryBrush}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    Padding="16,0,0,0"
                    Height="44"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Border Width="28" Height="28" CornerRadius="6"
                                Background="{StaticResource AccentPrimaryBrush}"
                                Margin="0,0,12,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE0D7;" FontFamily="{StaticResource FontLucide}" FontSize="14"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Profils" Style="{StaticResource TextHeading}"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Stretch"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="MinimizeButton" Style="{StaticResource WindowCaptionButtonStyle}"
                                Width="44" Height="32"
                                ClickMode="Press" Focusable="False" Foreground="{StaticResource TextPrimaryBrush}"
                                FontFamily="{StaticResource FontLucide}" FontSize="12" Content="&#xE11C;"
                                ToolTip="Réduire" Click="MinimizeButton_Click"/>
                        <Button x:Name="MaximizeButton" Style="{StaticResource WindowCaptionButtonStyle}"
                                Width="44" Height="32"
                                ClickMode="Press" Focusable="False" Foreground="{StaticResource TextPrimaryBrush}"
                                FontFamily="{StaticResource FontLucide}" FontSize="12" Content="&#xE167;"
                                ToolTip="Agrandir" Click="MaximizeButton_Click"/>
                        <Button x:Name="CloseButton" Style="{StaticResource WindowCaptionCloseButtonStyle}"
                                Width="44" Height="32"
                                ClickMode="Press" Focusable="False" Foreground="{StaticResource TextPrimaryBrush}"
                                FontFamily="{StaticResource FontLucide}" FontSize="12" Content="&#xE1B2;"
                                ToolTip="Fermer" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Corps : liste à gauche, détail à droite -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" MinWidth="260" MaxWidth="380"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Panneau gauche : liste des profils -->
                <Grid Grid.Column="0" Background="{StaticResource BackgroundSecondaryBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Bouton Nouveau profil -->
                    <Button x:Name="NewProfileButton" Grid.Row="0"
                            Style="{StaticResource ButtonPrimary}"
                            Click="NewProfileButton_Click"
                            HorizontalAlignment="Stretch"
                            Margin="20,16,20,0"
                            Padding="14,10"
                            ToolTip="Créer un nouveau profil">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE081;" FontFamily="{StaticResource FontLucide}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Nouveau profil" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <!-- Barre de séparation au-dessus de la liste (comme liste des macros) -->
                    <Border Grid.Row="1" Height="1" Background="{StaticResource SeparatorSubtleBrush}" Margin="0,0,0,8"/>

                    <!-- Liste des profils : même style que liste des macros -->
                    <Border Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            ClipToBounds="False" Background="Transparent" Margin="0,0,0,0">
                        <ScrollViewer Style="{StaticResource ScrollViewerNoClipStyle}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,0,0,12"
                                      Background="Transparent">
                            <ListBox x:Name="ProfilesListBox"
                                     Style="{StaticResource MacrosListBoxStyle}"
                                     SelectionMode="Single"
                                     SelectionChanged="ProfilesListBox_SelectionChanged"
                                     MouseDoubleClick="ProfilesListBox_MouseDoubleClick"
                                     ItemContainerStyle="{StaticResource MacroListItemStyle}">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel ClipToBounds="False"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid MaxHeight="40">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="26"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Icône à gauche (profil = dossier / layers) -->
                                            <Border Grid.Column="0" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,6,0">
                                                <TextBlock Text="&#xE0D7;" FontFamily="{StaticResource FontLucide}" FontSize="14"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>
                                            <!-- Nom du profil -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"/>
                                            <!-- Pastille "Actif" (style comme raccourci macros) -->
                                            <Border Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    Margin="6,0,0,0"
                                                    Padding="5,2,5,2"
                                                    BorderThickness="0"
                                                    CornerRadius="2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource BackgroundTertiaryBrush}"/>
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                                           Text="Actif"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Border>

                    <!-- Message statut (erreur / succès) -->
                    <TextBlock x:Name="StatusText" Grid.Row="3"
                               Foreground="{StaticResource ErrorBrush}"
                               FontSize="12" TextWrapping="Wrap"
                               Margin="20,8,20,0" Visibility="Collapsed"/>

                    <!-- Actions : Utiliser / Supprimer -->
                    <Border Grid.Row="4" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0"
                            Background="{StaticResource BackgroundSecondaryBrush}" Padding="20,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ActivateProfileButton" Grid.Column="0"
                                    Style="{StaticResource ButtonSecondary}"
                                    Click="ActivateProfileButton_Click"
                                    HorizontalAlignment="Stretch"
                                    Padding="12,8"
                                    IsEnabled="False"
                                    ToolTip="Utiliser ce profil comme profil actif">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE080;" FontFamily="{StaticResource FontLucide}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Utiliser" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="DeleteProfileButton" Grid.Column="2"
                                    Style="{StaticResource ButtonGhostDanger}"
                                    Click="DeleteProfileButton_Click"
                                    HorizontalAlignment="Stretch"
                                    Padding="12,8"
                                    IsEnabled="False"
                                    ToolTip="Supprimer le profil sélectionné">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE18E;" FontFamily="{StaticResource FontLucide}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Supprimer" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Trait de séparation -->
                <Border Grid.Column="1" Background="{StaticResource BorderLightBrush}"/>

                <!-- Panneau droit : détail / éditeur -->
                <Grid Grid.Column="2" Background="{StaticResource BackgroundPrimaryBrush}">
                    <Border Background="{StaticResource BackgroundSecondaryBrush}"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1,0,0,0"
                            CornerRadius="0"
                            Margin="0"
                            Padding="0">
                        <Grid>
                            <ScrollViewer x:Name="EditorScrollViewer"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="24,20"
                                          Background="Transparent">
                                <ContentControl x:Name="EditorContent"/>
                            </ScrollViewer>
                            <!-- Placeholder quand aucun profil sélectionné -->
                            <StackPanel x:Name="PlaceholderPanel"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        IsHitTestVisible="False">
                                <Border Width="56" Height="56" CornerRadius="28"
                                        Background="{StaticResource BackgroundTertiaryBrush}"
                                        Margin="0,0,0,16">
                                    <TextBlock Text="&#xE0D7;" FontFamily="{StaticResource FontLucide}" FontSize="24"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="PlaceholderText"
                                           Text="Sélectionnez un profil ou créez-en un nouveau."
                                           Style="{StaticResource TextMuted}"
                                           FontSize="14"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="260"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
