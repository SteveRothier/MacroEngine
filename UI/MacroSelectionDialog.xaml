<Window x:Class="MacroEngine.UI.MacroSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Sélectionner des Macros"
        Width="520" Height="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        MinWidth="440" MinHeight="380"
        Background="{StaticResource BackgroundPrimaryBrush}">
    <Border x:Name="RootBorder"
            Background="{StaticResource BackgroundPrimaryBrush}"
            BorderBrush="{StaticResource BorderLightBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Barre de titre -->
            <Border x:Name="TitleBarBorder" Grid.Row="0"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Background="{StaticResource BackgroundSecondaryBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,0,0,0" Height="40"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="&#xE081;" FontFamily="{StaticResource FontLucide}" FontSize="18"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,10,0"/>
                        <TextBlock Text="Sélectionner des Macros" Style="{StaticResource TextHeading}"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="15"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Stretch"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="MinimizeButton" Style="{StaticResource WindowCaptionButtonStyle}"
                                ClickMode="Press" Focusable="False" Foreground="{StaticResource TextPrimaryBrush}"
                                FontFamily="{StaticResource FontLucide}" Content="&#xE11C;"
                                ToolTip="Réduire" Click="MinimizeButton_Click"/>
                        <Button x:Name="MaximizeButton" Style="{StaticResource WindowCaptionButtonStyle}"
                                ClickMode="Press" Focusable="False" Foreground="{StaticResource TextPrimaryBrush}"
                                FontFamily="{StaticResource FontLucide}" Content="&#xE167;"
                                ToolTip="Agrandir" Click="MaximizeButton_Click"/>
                        <Button x:Name="CloseButton" Style="{StaticResource WindowCaptionCloseButtonStyle}"
                                ClickMode="Press" Focusable="False" Foreground="{StaticResource TextPrimaryBrush}"
                                FontFamily="{StaticResource FontLucide}" Content="&#xE1B2;"
                                ToolTip="Fermer" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Liste des macros -->
            <Border Grid.Row="1" Margin="20,16,20,12"
                    Background="{StaticResource BackgroundSecondaryBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="8">
                <ListBox x:Name="MacrosListBox" Background="Transparent" BorderThickness="0"
                         SelectionMode="Multiple">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" Margin="0,0,0,4" CornerRadius="6"
                                    Background="{StaticResource BackgroundTertiaryBrush}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis" LineHeight="18" MaxHeight="18"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               TextTrimming="CharacterEllipsis" LineHeight="16" MaxHeight="16"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Boutons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="20,0,20,20">
                <Button x:Name="OkButton" Style="{StaticResource ButtonPrimary}"
                        Content="OK" Click="Ok_Click"
                        Padding="14,8" Margin="0,0,8,0"
                        ToolTip="Ajouter les macros sélectionnées"/>
                <Button x:Name="CancelButton" Style="{StaticResource ButtonSecondary}"
                        Content="Annuler" Click="Cancel_Click"
                        Padding="14,8"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
