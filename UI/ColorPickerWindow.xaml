<Window x:Class="MacroEngine.UI.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pipette Couleur"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#01000000"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Cursor="None"
        IsHitTestVisible="False">
    <Canvas x:Name="OverlayCanvas">
        <!-- Loupe circulaire, position mise à jour en code -->
        <Border x:Name="LoupeBorder" Width="99" Height="99"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="49.5"
                ClipToBounds="True">
            <Grid>
                <!-- Pixels zoomés (rempli par WriteableBitmap en code) -->
                <Image x:Name="LoupeImage" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                <!-- Grille (dessinée en code) -->
                <Canvas x:Name="GridLines" IsHitTestVisible="False"/>
                <!-- Pixel central surligné : cadre à l'extérieur pour ne pas cacher le centre -->
                <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                        BorderBrush="#E6FFFFFF" BorderThickness="2.5"
                        IsHitTestVisible="False" Width="14" Height="14">
                    <Border x:Name="CenterPixelBorder" Width="9" Height="9"
                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                </Grid>
        </Border>
        <!-- Tooltip couleur sous la loupe -->
        <Border x:Name="TooltipBorder" Padding="6,4" Background="#E01E1E1E"
                BorderBrush="#4DFFFFFF" BorderThickness="1"
                IsHitTestVisible="False">
            <StackPanel Orientation="Horizontal">
                <Border x:Name="TooltipSwatch" Width="12" Height="12" Margin="0,0,6,0"
                        BorderBrush="#26FFFFFF" BorderThickness="1" Background="Black"/>
                <TextBlock x:Name="TooltipHex" Text="#000000" FontFamily="Consolas" FontSize="11"
                           FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Canvas>
</Window>
