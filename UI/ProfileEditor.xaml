<UserControl x:Class="MacroEngine.UI.ProfileEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="400">
    <UserControl.Resources>
        <!-- TextBox recherche : pas de bordure pourpre au focus -->
        <Style x:Key="MacroSearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nom du profil : label au-dessus, champ pleine largeur -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Nom du profil" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
            <TextBox x:Name="ProfileNameTextBox" Style="{StaticResource TextBoxModern}" VerticalAlignment="Center"/>
            <TextBlock x:Name="ProfileNameErrorText"
                       Text="Le nom ne peut pas être vide."
                       Foreground="{StaticResource ErrorBrush}" FontSize="12" Margin="0,4,0,0"
                       Visibility="Collapsed"/>
        </StackPanel>

        <!-- Macros du profil -->
        <Border Grid.Row="1" Background="{StaticResource BackgroundTertiaryBrush}"
                BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                CornerRadius="6" Padding="16" Margin="0,0,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="180" MaxHeight="360"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Macros inclus" Style="{StaticResource TextSubheading}"
                           Margin="0,0,0,12"/>
                <!-- Barre d'outils : Ajouter, Retirer, Recherche -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource ButtonGhost}" Click="AddMacro_Click"
                            Padding="8,6" MinWidth="32" Width="32" ToolTip="Ajouter une macro">
                        <TextBlock Text="&#xE081;" FontFamily="{StaticResource FontLucide}" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Button>
                    <Button Grid.Column="1" Style="{StaticResource ButtonGhost}" Click="RemoveMacro_Click"
                            Padding="8,6" MinWidth="32" Width="32" Margin="4,0,0,0" ToolTip="Retirer la sélection">
                        <TextBlock Text="&#xE18E;" FontFamily="{StaticResource FontLucide}" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Button>
                    <Border Grid.Column="3" VerticalAlignment="Center"
                            Background="{StaticResource BackgroundPrimaryBrush}"
                            BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="8,6" MinWidth="140">
                        <Grid>
                            <TextBlock x:Name="MacroSearchPlaceholder" Text="Rechercher..."
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                                       IsHitTestVisible="False" VerticalAlignment="Center"/>
                            <TextBox x:Name="MacroSearchTextBox" Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}"
                                     Padding="0" VerticalContentAlignment="Center"
                                     TextChanged="MacroSearchTextBox_TextChanged"
                                     Style="{StaticResource MacroSearchTextBoxStyle}"/>
                        </Grid>
                    </Border>
                </Grid>
                <ListBox x:Name="ProfileMacrosListBox" Grid.Row="2" Background="Transparent" BorderThickness="0"
                         SelectionMode="Multiple" Padding="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.CanContentScroll="False"
                         VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                         HorizontalContentAlignment="Center">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"
                                       ItemWidth="200" ItemHeight="40"
                                       Margin="0,0,8,8"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="Transparent">
                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                              Margin="{TemplateBinding Padding}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" Margin="0,0,8,8" Background="{StaticResource BackgroundPrimaryBrush}"
                                    CornerRadius="4" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource SidebarAccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Name}" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Boutons Annuler / Sauvegarder -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annuler" Style="{StaticResource ButtonGhost}"
                    Click="Cancel_Click" Padding="12,8" Margin="0,0,8,0"
                    ToolTip="Abandonner les modifications"/>
            <Button Content="Sauvegarder" Style="{StaticResource ButtonPrimary}"
                    Click="SaveProfile_Click" Padding="12,8"
                    ToolTip="Enregistrer les modifications du profil"/>
        </StackPanel>
    </Grid>
</UserControl>
