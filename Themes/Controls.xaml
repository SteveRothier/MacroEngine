    <!-- Items du ComboBox action Si (carte rouge) : option sélectionnée en rouge -->
    <Style x:Key="ComboBoxItemSiRed" TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="{StaticResource BlockSiRedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         CHECKBOX
         ══════════════════════════════════════════════════════════════════════ -->

    <Style x:Key="CheckBoxModern" TargetType="CheckBox">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="checkBorder" Width="18" Height="18" 
                                Background="{StaticResource BackgroundTertiaryBrush}"
                                BorderBrush="{StaticResource BorderLightBrush}"
                                BorderThickness="1.5"
                                CornerRadius="{StaticResource RadiusSmall}"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center">
                            <Path x:Name="checkMark" Data="M 2,6 L 6,10 L 14,2" 
                                  Stroke="{StaticResource TextOnAccentBrush}" StrokeThickness="2"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Visibility="Collapsed"/>
                        </Border>
                        <ContentPresenter x:Name="contentPresenter" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="checkBorder" Property="Background" Value="{StaticResource AccentPrimaryBrush}"/>
                            <Setter TargetName="checkBorder" Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
                            <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="checkBorder" Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="CheckBox" BasedOn="{StaticResource CheckBoxModern}"/>

    <!-- ══════════════════════════════════════════════════════════════════════
         SCROLLBAR PERSONNALISÉE (appliquée partout)
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- Style du curseur (thumb) de la scrollbar -->
    <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbBorder"
                            Background="{StaticResource BorderLightBrush}"
                            Margin="0"
                            MinWidth="14"
                            MinHeight="24"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource TextMutedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource TextSecondaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- RepeatButton pour les flèches / zone de la scrollbar -->
    <Style x:Key="ScrollBarRepeatButtonStyle" TargetType="RepeatButton">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            MinWidth="10"
                            MinHeight="10">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource BackgroundTertiaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ScrollBar -->
    <Style x:Key="ScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Width" Value="14"/>
        <Setter Property="MinWidth" Value="14"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="ContextMenu" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Border Background="{StaticResource BackgroundTertiaryBrush}"
                            Width="14"
                            MinWidth="14"
                            MaxWidth="14"
                            Padding="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch">
                        <Track x:Name="PART_Track" IsDirectionReversed="True"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ScrollBarRepeatButtonStyle}"
                                              Command="ScrollBar.PageUpCommand"
                                              Focusable="False"/>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ScrollBarRepeatButtonStyle}"
                                              Command="ScrollBar.PageDownCommand"
                                              Focusable="False"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                            </Track.Thumb>
                        </Track>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Style par défaut pour ScrollBar -->
    <Style TargetType="ScrollBar" BasedOn="{StaticResource ScrollBarStyle}"/>

    <!-- ScrollBar fine = bordure droite (picker liste processus), même rendu que les autres bordures 1px -->
    <Style x:Key="ScrollBarBorderThumbStyle" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbBorder"
                            Background="{StaticResource BorderLightBrush}"
                            Margin="0"
                            MinWidth="1"
                            MinHeight="20"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource TextMutedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource TextSecondaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="ScrollBarBorderStyle" TargetType="ScrollBar">
        <Setter Property="Width" Value="2"/>
        <Setter Property="MinWidth" Value="2"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="ContextMenu" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <!-- Bordure droite du picker = cette barre (pas de bordure en plus) -->
                    <Border Background="Transparent"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="0,0,1,0"
                            Width="2"
                            MinWidth="2"
                            MaxWidth="2"
                            Padding="0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <Track x:Name="PART_Track" IsDirectionReversed="True"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Focusable="False"
                                              Background="Transparent" BorderThickness="0" Padding="0" MinWidth="0" MinHeight="0"/>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Focusable="False"
                                              Background="Transparent" BorderThickness="0" Padding="0" MinWidth="0" MinHeight="0"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollBarBorderThumbStyle}"/>
                            </Track.Thumb>
                        </Track>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ScrollViewer : barre verticale = bordure droite du picker (pas de bordure ajoutée) -->
    <Style x:Key="ScrollViewerBorderRightStyle" TargetType="ScrollViewer">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2" MinWidth="2"/>
                        </Grid.ColumnDefinitions>
                        <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                Grid.Column="0"
                                                CanContentScroll="{TemplateBinding CanContentScroll}"
                                                CanHorizontallyScroll="False"
                                                CanVerticallyScroll="False"
                                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                                Content="{TemplateBinding Content}"
                                                Margin="{TemplateBinding Padding}"/>
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Grid.Column="1"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                   Orientation="Vertical"
                                   Style="{StaticResource ScrollBarBorderStyle}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ListBox picker : scroll = bordure droite -->
    <Style x:Key="ListBoxPickerBorderScrollStyle" TargetType="ListBox">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Style="{StaticResource ScrollViewerBorderRightStyle}"
                                      Focusable="False"
                                      CanContentScroll="True">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ListBoxItem picker : hover discret, pas de bleu -->
    <Style x:Key="ListBoxItemPickerStyle" TargetType="ListBoxItem">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BackgroundTertiaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ScrollViewer personnalisé : applique nos scrollbars partout -->
    <Style TargetType="ScrollViewer">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14" MinWidth="14"/>
                        </Grid.ColumnDefinitions>
                        <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                Grid.Column="0"
                                                CanContentScroll="{TemplateBinding CanContentScroll}"
                                                CanHorizontallyScroll="False"
                                                CanVerticallyScroll="False"
                                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                                Content="{TemplateBinding Content}"
                                                Margin="{TemplateBinding Padding}"/>
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Grid.Column="1"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                   Orientation="Vertical"
                                   Style="{StaticResource ScrollBarStyle}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         COLONNE MACROS (panneau moteur)
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- ══════════════════════════════════════════════════════════════════════
         PANNEAUX ET CARTES
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- Carte/Panneau avec fond et ombre -->
    <Style x:Key="PanelCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusPanel}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="Black" Opacity="0.35" BlurRadius="10" ShadowDepth="2" Direction="270"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Colonnes mécaniques : style technique léger (gradient discret, bordure 1px, coins 4px) -->
    <Style x:Key="PanelColumnMetallic" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ColumnMechanicalBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ColumnMechanicalBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <!-- Ligne d'accent technique Niveau 3 : barre dégradé transparent → cuivre → transparent (left 12px, right 12px) -->
    <Style x:Key="ColumnAccentLine" TargetType="Border">
        <Setter Property="Height" Value="2"/>
        <Setter Property="Background" Value="{StaticResource ColumnAccentLineGradientBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="12,0,12,0"/>
    </Style>
    <!-- Inset : highlight haut (plaque usinée) -->
    <Style x:Key="ColumnInsetHighlight" TargetType="Border">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Background" Value="{StaticResource ColumnInsetHighlightBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <!-- Inset : ombre bas -->
    <Style x:Key="ColumnInsetShadow" TargetType="Border">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Background" Value="{StaticResource ColumnInsetShadowBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <!-- Cadre fragmenté Niveau 4 : segments dans les coins (châssis CNC, 20×20px) -->
    <Style x:Key="ColumnCornerTopLeft" TargetType="Border">
        <Setter Property="Width" Value="20"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="BorderBrush" Value="{StaticResource ColumnCornerAccentBrush}"/>
        <Setter Property="BorderThickness" Value="2,2,0,0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
    </Style>
    <Style x:Key="ColumnCornerTopRight" TargetType="Border">
        <Setter Property="Width" Value="20"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="BorderBrush" Value="{StaticResource ColumnCornerAccentBrush}"/>
        <Setter Property="BorderThickness" Value="0,2,2,0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
    </Style>
    <Style x:Key="ColumnCornerBottomLeft" TargetType="Border">
        <Setter Property="Width" Value="20"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="BorderBrush" Value="{StaticResource ColumnCornerAccentBrush}"/>
        <Setter Property="BorderThickness" Value="2,0,0,2"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
    </Style>
    <Style x:Key="ColumnCornerBottomRight" TargetType="Border">
        <Setter Property="Width" Value="20"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="BorderBrush" Value="{StaticResource ColumnCornerAccentBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,2,2"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
    </Style>

    <!-- Panneau Propriétés - même cadre métallique + hover animé (glow cuivre) -->
    <Style x:Key="PanelProperties" TargetType="Border" BasedOn="{StaticResource PanelColumnMetallic}">
        <Setter Property="Background" Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="8" ShadowDepth="1" Direction="270"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#406B3E26"/>
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Effect.(DropShadowEffect.Opacity)"
                                             To="0.45" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="Effect.(DropShadowEffect.BlurRadius)"
                                             To="14" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <ColorAnimation Storyboard.TargetProperty="Effect.(DropShadowEffect.Color)"
                                            To="#6B3E26" Duration="0:0:0.15">
                                <ColorAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </ColorAnimation.EasingFunction>
                            </ColorAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Effect.(DropShadowEffect.Opacity)"
                                             To="0.35" Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseIn"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="Effect.(DropShadowEffect.BlurRadius)"
                                             To="10" Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseIn"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <ColorAnimation Storyboard.TargetProperty="Effect.(DropShadowEffect.Color)"
                                            To="#FF000000" Duration="0:0:0.2">
                                <ColorAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseIn"/>
                                </ColorAnimation.EasingFunction>
                            </ColorAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Wrapper élévation pour champs (marge seulement, pas d'ombre) -->
    <Style x:Key="PanelPropertiesFieldElevation" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <!-- Champs panneau Propriétés - input wrapper, bordure simple (sans glow ni effet) -->
    <Style x:Key="PanelPropertiesField" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BackgroundPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#806B3E26"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="#806B3E26"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Chip processus (Applications cibles) : fond + dégradé couleur icône (hover géré en code) -->
    <Style x:Key="ProcessChipStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="6,4,4,4"/>
        <Setter Property="Margin" Value="0,0,3,3"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <!-- Template ContextMenu réutilisable (chips, actions, etc.) : fond gris anthracite, sans blanc -->
    <ControlTemplate x:Key="ContextMenuDefaultTemplate" TargetType="ContextMenu">
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                Padding="{TemplateBinding Padding}">
            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
        </Border>
    </ControlTemplate>

    <Style x:Key="ContextMenuDefaultStyle" TargetType="ContextMenu">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Background" Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Template" Value="{StaticResource ContextMenuDefaultTemplate}"/>
    </Style>

    <!-- Template MenuItem réutilisable pour les menus contextuels -->
    <ControlTemplate x:Key="ContextMenuItemDefaultTemplate" TargetType="MenuItem">
        <Border x:Name="Bg" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
            <ContentPresenter ContentSource="Header" ContentTemplate="{TemplateBinding HeaderTemplate}" Content="{TemplateBinding Header}" VerticalAlignment="Center"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Bg" Property="Background" Value="{StaticResource BackgroundTertiaryBrush}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="ContextMenuItemDefaultStyle" TargetType="MenuItem">
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="Template" Value="{StaticResource ContextMenuItemDefaultTemplate}"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="Background" Value="{StaticResource BackgroundTertiaryBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Conteneur des chips (Applications cibles) : fond dégradé léger, bordure discrète -->
    <Style x:Key="PanelChipsContainer" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource BackgroundSecondaryColor}" Offset="0"/>
                    <GradientStop Color="{StaticResource BackgroundTertiaryColor}" Offset="0.5"/>
                    <GradientStop Color="{StaticResource BackgroundSecondaryColor}" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="{StaticResource BorderInternalBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <!-- Blocs panneau Propriétés - zones de contenu avec hover animé -->
    <Style x:Key="PanelPropertiesBlock" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BackgroundTertiaryBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#306B3E26"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         SÉPARATEURS
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- Séparateur horizontal -->
    <Style x:Key="SeparatorHorizontal" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BorderLightBrush}"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="0,8"/>
    </Style>

    <!-- Séparateur vertical -->
    <Style x:Key="SeparatorVertical" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BorderLightBrush}"/>
        <Setter Property="Width" Value="1"/>
        <Setter Property="Margin" Value="12,0"/>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         BLOCS SCRATCH-LIKE
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- Style de base pour tous les blocs (avec effet d'imbrication) -->
    <Style x:Key="ActionBlockBase" TargetType="Border">
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Effect" Value="{StaticResource ShadowActionBlock}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="MinHeight" Value="48"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Effect" Value="{StaticResource ShadowActionBlockHover}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Bloc Clavier (Bleu) -->
    <Style x:Key="BlockKeyboard" TargetType="Border" BasedOn="{StaticResource ActionBlockBase}">
        <Setter Property="Background" Value="{StaticResource BlockKeyboardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BlockActionBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,3"/>
    </Style>

    <!-- Bloc Souris (Vert) -->
    <Style x:Key="BlockMouse" TargetType="Border" BasedOn="{StaticResource ActionBlockBase}">
        <Setter Property="Background" Value="{StaticResource BlockMouseBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BlockActionBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,3"/>
    </Style>

    <!-- Bloc Délai (Jaune/Orange) -->
    <Style x:Key="BlockDelay" TargetType="Border" BasedOn="{StaticResource ActionBlockBase}">
        <Setter Property="Background" Value="{StaticResource BlockDelayBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BlockActionBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,3"/>
    </Style>

    <!-- Bloc Boucle/Loop (Violet) -->
    <Style x:Key="BlockLoop" TargetType="Border" BasedOn="{StaticResource ActionBlockBase}">
        <Setter Property="Background" Value="{StaticResource BlockLoopBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BlockLoopDarkBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,3"/>
    </Style>

    <!-- Texte sur les blocs (blanc / contraste sur couleurs) -->
    <Style x:Key="BlockText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextOnAccentBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Texte secondaire sur les blocs -->
    <Style x:Key="BlockTextSecondary" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#DDFFFFFF"/>
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Icône sur les blocs -->
    <Style x:Key="BlockIcon" TargetType="TextBlock">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,12,0"/>
    </Style>

    <!-- Bouton d'ajout de bloc (+) -->
    <Style x:Key="BlockAddButton" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnAccentBrush}"/>
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="48"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="0"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}">
                        <TextBlock Text="&#xE081;" 
                                   FontFamily="{StaticResource FontLucide}"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   Foreground="{TemplateBinding Foreground}"
                                   Margin="0,-2,0,0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" 
                                    Value="{StaticResource AccentHoverBrush}"/>
                            <Setter TargetName="border" Property="Effect" 
                                    Value="{StaticResource ShadowButtonHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" 
                                    Value="{StaticResource AccentPressedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Bouton de suppression sur les blocs -->
    <Style x:Key="BlockDeleteButton" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnAccentBrush}"/>
        <Setter Property="Width" Value="24"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Visibility" Value="Collapsed"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="0"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}">
                        <TextBlock Text="&#xE084;" 
                                   FontFamily="{StaticResource FontLucide}"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   FontSize="{TemplateBinding FontSize}"
                                   Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
