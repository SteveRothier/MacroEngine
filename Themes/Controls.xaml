<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="clr-namespace:MacroEngine.UI">

    <!-- ══════════════════════════════════════════════════════════════════════
         MacroEngine - Styles des Contrôles
         Dépend de: Colors.xaml, Typography.xaml
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- Désactiver la bordure en pointillés au focus pour tous les contrôles -->
    <Style TargetType="Control">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>
    <!-- Remplacer le focus visuel système (pointillés noirs) par un style vide -->
    <Style x:Key="{x:Static SystemParameters.FocusVisualStyleKey}" TargetType="Control">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Control"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         TOOLTIP (style global, couleurs thème)
         ══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         TOGGLE SWITCH
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- Toggle mécanique type module industriel : plaque, logement encastré, levier massif, LED -->
    <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="MinWidth" Value="56"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <!-- 1. Plaque (support acier/aluminium, dégradé vertical matière dense) -->
                    <Border x:Name="plaque"
                            Height="28"
                            MinWidth="56"
                            CornerRadius="5"
                            Padding="2"
                            BorderThickness="1"
                            BorderBrush="#2A2A2A">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.25" BlurRadius="2" ShadowDepth="1" Direction="270"/>
                        </Border.Effect>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Color="#4A4A4A" Offset="0"/>
                                <GradientStop Color="#404040" Offset="0.25"/>
                                <GradientStop Color="#383838" Offset="0.5"/>
                                <GradientStop Color="#323232" Offset="0.75"/>
                                <GradientStop Color="#2E2E2E" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <!-- 2. Logement (encastrement, ombre interne, plus sombre) -->
                        <Border x:Name="logement"
                                CornerRadius="3"
                                Padding="3"
                                Background="#1C1C1C">
                            <Grid>
                                <!-- Désactivé : [levier gauche] [point droite] -->
                                <Grid x:Name="layoutOff" Visibility="Visible">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="levierOff"
                                            Grid.Column="0"
                                            MinWidth="22" Height="18" CornerRadius="2"
                                            VerticalAlignment="Center" HorizontalAlignment="Left"
                                            Margin="2,0,0,0"
                                            BorderThickness="1" BorderBrush="#353535">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="2" ShadowDepth="1" Direction="270"/>
                                        </Border.Effect>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                <GradientStop Color="#5C5C5C" Offset="0"/>
                                                <GradientStop Color="#4A4A4A" Offset="0.4"/>
                                                <GradientStop Color="#404040" Offset="0.7"/>
                                                <GradientStop Color="#383838" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Ellipse x:Name="ledOff" Grid.Column="1" Width="5" Height="5" Margin="6,0,0,0"
                                             VerticalAlignment="Center" Fill="#2A2A2A"/>
                                </Grid>
                                <!-- Activé : [point gauche] [levier droite] -->
                                <Grid x:Name="layoutOn" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse x:Name="ledOn" Grid.Column="0" Width="5" Height="5" Margin="0,0,6,0"
                                             VerticalAlignment="Center" Fill="#6B3E26">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="#6B3E26" BlurRadius="6" ShadowDepth="0" Opacity="0.6"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <Border x:Name="levierOn"
                                            Grid.Column="1"
                                            MinWidth="22" Height="18" CornerRadius="2"
                                            VerticalAlignment="Center" HorizontalAlignment="Right"
                                            Margin="0,0,2,0"
                                            BorderThickness="1" BorderBrush="#4A2819">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="2" ShadowDepth="1" Direction="270"/>
                                        </Border.Effect>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                <GradientStop Color="#8A5A3A" Offset="0"/>
                                                <GradientStop Color="#6B3E26" Offset="0.4"/>
                                                <GradientStop Color="#5A3520" Offset="0.8"/>
                                                <GradientStop Color="#4A2819" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- État activé : afficher layout [point gauche][levier droite] -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="layoutOff" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="layoutOn" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <!-- Feedback mécanique au clic : levier descend légèrement -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="levierOff" Property="Margin" Value="2,1,0,0"/>
                            <Setter TargetName="levierOff" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="1" ShadowDepth="0" Direction="270"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="levierOn" Property="Margin" Value="0,1,2,0"/>
                            <Setter TargetName="levierOn" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="1" ShadowDepth="0" Direction="270"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="plaque" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Toggle compact pour liste (pill : gris = off, cuivre = on) -->
    <Style x:Key="ToggleSwitchStyleCompact" TargetType="ToggleButton">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="pill" CornerRadius="9" Cursor="Hand" Background="#2A2830"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="pill" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="pill" Property="Opacity" Value="0.9"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="pill" Property="Opacity" Value="0.8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         BADGES
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- Point d'état (Activé/Désactivé) - Simple point lumineux -->
    <Style x:Key="StatusDotStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="10"/>
        <Setter Property="Height" Value="10"/>
        <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="8,0,0,0"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="{StaticResource SuccessColor}" Opacity="0.5" BlurRadius="4" ShadowDepth="0"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                <Setter Property="Fill" Value="{StaticResource TextMutedBrush}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="{StaticResource TextMutedColor}" Opacity="0.35" BlurRadius="3" ShadowDepth="0"/>
                    </Setter.Value>
                </Setter>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Badge de raccourci clavier -->
    <Style x:Key="ShortcutBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BackgroundTertiaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderMediumBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="8,0,0,0"/>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════════
         BOUTONS
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- Bouton principal (accent) -->
    <Style x:Key="ButtonPrimary" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnAccentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusButton}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" 
                                    Value="{StaticResource AccentHoverBrush}"/>
                            <Setter TargetName="border" Property="Effect" 
                                    Value="{StaticResource ShadowButtonHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" 
                                    Value="{StaticResource AccentPressedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Bouton secondaire (outline) -->
    <Style x:Key="ButtonSecondary" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderMediumBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusButton}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" 
                                    Value="{StaticResource BackgroundTertiaryBrush}"/>
                            <Setter TargetName="border" Property="BorderBrush" 
                                    Value="{StaticResource AccentPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" 
                                    Value="{StaticResource BackgroundSecondaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Bouton ghost (texte uniquement) -->
    <Style x:Key="ButtonGhost" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusButton}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" 
                                    Value="{StaticResource BackgroundTertiaryBrush}"/>
                            <Setter Property="Foreground" 
                                    Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" 
                                    Value="{StaticResource BackgroundSecondaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Bouton Supprimer rail (btn-del v2 : transparent, bordure line2, hover rouge) -->
    <Style x:Key="ButtonGhostDanger" TargetType="Button" BasedOn="{StaticResource ButtonGhost}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderMediumBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
        <Setter Property="FontSize" Value="9"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ErrorDimBrush}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ErrorDimBrush}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- Bouton compact pour panneau Propriétés (Définir, Sélectionner) -->
    <Style x:Key="ButtonPropertiesAction" TargetType="Button" BasedOn="{StaticResource ButtonGhost}">
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="MinHeight" Value="26"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
    </Style>

    <!-- Bouton icône (carré) -->
    <Style x:Key="ButtonIcon" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusButton}"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}">
                        <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" 
                                    Value="{StaticResource BackgroundTertiaryBrush}"/>
                            <Setter Property="Foreground" 
                                    Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" 
                                    Value="{StaticResource BackgroundSecondaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Bouton icône Undo : rotation inverse (sens anti-horaire) au clic -->
    <Style x:Key="ButtonIconUndo" TargetType="Button" BasedOn="{StaticResource ButtonIcon}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusButton}"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}">
                        <Border x:Name="iconHost" RenderTransformOrigin="0.5,0.5"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border.RenderTransform>
                                <RotateTransform x:Name="iconRotate" Angle="0"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{StaticResource BackgroundTertiaryBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="Transparent"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                        <EventTrigger RoutedEvent="Click">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="iconHost"
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                     From="0" To="-360" Duration="0:0:0.8">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Bouton icône Redo : rotation sens horaire au clic -->
    <Style x:Key="ButtonIconRedo" TargetType="Button" BasedOn="{StaticResource ButtonIcon}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusButton}"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}">
                        <Border x:Name="iconHost" RenderTransformOrigin="0.5,0.5"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border.RenderTransform>
                                <RotateTransform x:Name="iconRotate" Angle="0"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{StaticResource BackgroundTertiaryBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="Transparent"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                        <EventTrigger RoutedEvent="Click">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="iconHost"
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                     From="0" To="360" Duration="0:0:0.8">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Bouton d'ajout d'action (barre d'outils éditeur) : couleurs par Background, hover/état cohérents -->
    <Style x:Key="ToolbarAddActionButtonStyle" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.78"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Boutons barre de titre fenêtre (Réduire / Agrandir) -->
    <Style x:Key="WindowCaptionButtonStyle" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundTertiaryBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundSecondaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
