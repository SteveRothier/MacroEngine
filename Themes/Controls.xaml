    <!-- ══════════════════════════════════════════════════════════════════════
         BOUTONS SIDEBAR (Palette cuivre)
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- Transforms pour effet hover CTA (translateY -1px) -->
    <TranslateTransform x:Key="TranslateY0" Y="0"/>
    <TranslateTransform x:Key="TranslateYUp1" Y="-1"/>

    <!-- Bouton "Nouvelle Macro" (CTA v2 – forme polygonale clip-path : coins haut-droite / bas-gauche coupés) -->
    <Style x:Key="ButtonSidebarPrimary" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnAccentBrush}"/>
        <Setter Property="Padding" Value="9,9"/>
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="ExtraBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <!-- Forme polygonale (équivalent clip-path: polygon(0 0, calc(100%-8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100%-8px))) -->
                        <Path x:Name="shapePath"
                              Data="M 0,0 L 0.955,0 L 1,0.22 L 1,1 L 0.045,1 L 0,0.78 Z"
                              Fill="{TemplateBinding Background}"
                              Stretch="Fill"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            <Setter TargetName="shapePath" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#59E8A020" BlurRadius="24" ShadowDepth="0" Opacity="1"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentPressedBrush}"/>
                            <Setter TargetName="shapePath" Property="Effect" Value="{x:Null}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="shapePath" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Boutons Importer/Exporter (rail-btn v2 : transparent, bordure line2, hover ambre) -->
