    <!-- ComboBox style « click-select » : trigger + caret (rotation/couleur à l’ouverture), dropdown bg2/line2, options mono 11px -->
    <Style x:Key="ComboBoxNoBackground" TargetType="ComboBox" BasedOn="{StaticResource ComboBoxModern}">
        <Setter Property="Background" Value="Transparent"/>
