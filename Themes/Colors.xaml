<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════════════════════════
         MacroEngine - Palette de Couleurs (v2 – thème sombre vert / ambre)
         Inspiré du mockup MacroEngine v2 : fonds #08xxx, accent ambre, texte vert gris
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- Fonds principaux (verts très sombres) -->
    <Color x:Key="BackgroundPrimaryColor">#080A08</Color>
    <Color x:Key="BackgroundSecondaryColor">#0D0F0D</Color>
    <Color x:Key="BackgroundTertiaryColor">#111311</Color>
    
    <!-- Fonds niveau 3–4 (rail, cartes) -->
    <Color x:Key="BackgroundLevel3Color">#161916</Color>
    <Color x:Key="BackgroundLevel4Color">#1C201C</Color>
    
    <!-- Accent principal – Ambre (signature v2) -->
    <Color x:Key="AccentPrimaryColor">#E8A020</Color>
    <Color x:Key="AccentHoverColor">#F0B840</Color>
    <Color x:Key="AccentPressedColor">#C98A18</Color>
    <Color x:Key="AccentSelectionColor">#1F1A08</Color>
    <Color x:Key="AccentSecondaryColor">#E8A020</Color>
    
    <!-- Sidebar / sélection : ambre + fonds verts -->
    <Color x:Key="SidebarAccentColor">#E8A020</Color>
    <Color x:Key="SidebarAccentLightColor">#1F1A08</Color>
    <Color x:Key="SidebarAccentSelectedColor">#161916</Color>
    <Color x:Key="SidebarAccentHoverColor">#1C201C</Color>
    <Color x:Key="SidebarAccentBorderColor">#E8A020</Color>
    
    <!-- Texte (vert gris) -->
    <Color x:Key="TextPrimaryColor">#C8D4C8</Color>
    <Color x:Key="TextSecondaryColor">#7A927A</Color>
    <Color x:Key="TextMutedColor">#4A5A4A</Color>
    <Color x:Key="TextOnAccentColor">#0A0A00</Color>
    
    <!-- États -->
    <Color x:Key="WarningColor">#E8A020</Color>
    <Color x:Key="ErrorColor">#E84040</Color>
    <Color x:Key="SuccessColor">#39D97A</Color>
    <Color x:Key="InfoColor">#34C8B8</Color>
    
    <!-- Bordures et lignes (#5A5D5A = même teinte que bordures blocs d'action) -->
    <Color x:Key="BorderLightColor">#5A5D5A</Color>
    <Color x:Key="BorderFocusColor">#E8A020</Color>
    <Color x:Key="BorderInternalColor">#5A5D5A</Color>
    <Color x:Key="BorderMediumColor">#5A5D5A</Color>
    <Color x:Key="BorderDarkColor">#5A5D5A</Color>
    <Color x:Key="BorderBevelHighlightColor">#20FFFFFF</Color>
    <Color x:Key="BorderBevelShadowColor">#80000000</Color>
    <Color x:Key="ColumnCornerAccentColor">#E8A020</Color>
    <Color x:Key="BorderMechanicalEdgeColor">#5A5D5A</Color>
    <Color x:Key="BorderMechanicalInsetAccentColor">#26E8A020</Color>

    <!-- Ombres (couleurs pour DropShadowEffect) -->
    <Color x:Key="ShadowColor">#59000000</Color>
    <Color x:Key="ShadowHoverColor">#80000000</Color>
    <Color x:Key="GlowAccentColor">#596B3E26</Color>
    <Color x:Key="GlowAccentSubtleColor">#2E6B3E26</Color>

    <!-- ══════════════════════════════════════════════════════════════════════
         Couleurs des blocs d'action (Timeline / cartes)
         ══════════════════════════════════════════════════════════════════════ -->
    
    <!-- Touche / Clavier - Bleu froid précis -->
    <Color x:Key="BlockKeyboardColor">#4FA3D1</Color>
    <Color x:Key="BlockKeyboardDarkColor">#3E92C0</Color>
    
    <!-- Souris / Clic - Vert technique -->
    <Color x:Key="BlockMouseColor">#4FB58C</Color>
    <Color x:Key="BlockMouseDarkColor">#3EA47B</Color>
    
    <!-- Texte - Jaune chaud lisible -->
    <Color x:Key="BlockTextColor">#E0B15A</Color>
    <Color x:Key="BlockTextDarkColor">#CFA049</Color>
    
    <!-- Délai - Orange timing -->
    <Color x:Key="BlockDelayColor">#C97A3A</Color>
    <Color x:Key="BlockDelayDarkColor">#B86929</Color>
    
    <!-- Répéter / Boucle - Violet logique -->
    <Color x:Key="BlockLoopColor">#8A6CD1</Color>
    <Color x:Key="BlockLoopDarkColor">#795BC0</Color>
    <!-- Répéter (carte) - Vert mockup -->
    <Color x:Key="BlockRepeatGreenColor">#39D97A</Color>
    
    <!-- Si / Condition - Rouge décisionnel -->
    <Color x:Key="BlockConditionColor">#C94A4A</Color>
    <Color x:Key="BlockConditionDarkColor">#B83939</Color>
    <!-- Si (carte style Répéter) - Rouge #e84040 -->
    <Color x:Key="BlockSiRedColor">#E84040</Color>
    
    <!-- Variable - Cyan neutre / data -->
    <Color x:Key="BlockVariableColor">#5AA3A3</Color>
    <Color x:Key="BlockVariableDarkColor">#499292</Color>

    <!-- Bordure commune des blocs d'action (clic / délai / touche / variable / texte) -->
    <Color x:Key="BlockActionBorderColor">#5A5D5A</Color>

    <!-- Barre d'outils : bas de dégradé plus marqué (plus sombre) -->
    <Color x:Key="BlockKeyboardToolbarBottomColor">#2D7AA8</Color>
    <Color x:Key="BlockMouseToolbarBottomColor">#2D8A6A</Color>
    <Color x:Key="BlockTextToolbarBottomColor">#A67A30</Color>
    <Color x:Key="BlockVariableToolbarBottomColor">#357272</Color>
    <Color x:Key="BlockDelayToolbarBottomColor">#8F5218</Color>
    <Color x:Key="BlockConditionToolbarBottomColor">#8F2828</Color>
    <Color x:Key="BlockLoopToolbarBottomColor">#5A3D98</Color>
    
    <!-- Fond éditeur / grille -->
    <Color x:Key="EditorGridColor">#25222B</Color>

    <!-- ══════════════════════════════════════════════════════════════════════
         Brushes (SolidColorBrush)
         ══════════════════════════════════════════════════════════════════════ -->
    
    <!-- Fonds -->
    <SolidColorBrush x:Key="BackgroundPrimaryBrush" Color="{StaticResource BackgroundPrimaryColor}"/>
    <SolidColorBrush x:Key="BackgroundSecondaryBrush" Color="{StaticResource BackgroundSecondaryColor}"/>
    <SolidColorBrush x:Key="BackgroundTertiaryBrush" Color="{StaticResource BackgroundTertiaryColor}"/>
    <SolidColorBrush x:Key="BackgroundLevel3Brush" Color="{StaticResource BackgroundLevel3Color}"/>
    <SolidColorBrush x:Key="BackgroundLevel4Brush" Color="{StaticResource BackgroundLevel4Color}"/>
    <!-- Ambre avec opacité ~12 % (équivalent rgba(232,160,32,0.12)) -->
    <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource AccentPrimaryColor}" Opacity="0.12"/>
    <!-- Colonnes mécaniques : gradient 145° métal moderne (#232326 → #1C1C1F) -->
    <LinearGradientBrush x:Key="ColumnMechanicalBackgroundBrush" StartPoint="0.2,0" EndPoint="0.8,1">
        <GradientStop Color="#232326" Offset="0"/>
        <GradientStop Color="#1C1C1F" Offset="1"/>
    </LinearGradientBrush>
    <!-- Bordure fine structurante (1px, faible opacité) -->
    <SolidColorBrush x:Key="ColumnMechanicalBorderBrush" Color="#12E6E4EA"/>
    <!-- Inset Niveau 2 : highlight 1px rgba(255,255,255,0.05) / ombre rgba(0,0,0,0.6) -->
    <SolidColorBrush x:Key="ColumnInsetHighlightBrush" Color="#0DFFFFFF"/>
    <SolidColorBrush x:Key="ColumnInsetShadowBrush" Color="#99000000"/>
    <!-- Ligne d'accent technique : dégradé transparent → cuivre → transparent (barre élégante) -->
    <LinearGradientBrush x:Key="ColumnAccentLineGradientBrush" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="Transparent" Offset="0"/>
        <GradientStop Color="#B87333" Offset="0.5"/>
        <GradientStop Color="Transparent" Offset="1"/>
    </LinearGradientBrush>
    <!-- Cadre fragmenté (coins châssis CNC) -->
    <SolidColorBrush x:Key="ColumnCornerAccentBrush" Color="{StaticResource ColumnCornerAccentColor}"/>

    <!-- CTA "Nouvelle Macro" : ambre plein (v2) -->
    <LinearGradientBrush x:Key="AccentCtaGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentHoverColor}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentPrimaryColor}" Offset="0.5"/>
        <GradientStop Color="{StaticResource AccentPressedColor}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentCtaHoverGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F0B840" Offset="0"/>
        <GradientStop Color="{StaticResource AccentHoverColor}" Offset="0.5"/>
        <GradientStop Color="{StaticResource AccentPrimaryColor}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Barre gauche macro sélectionnée : ambre (v2) -->
    <LinearGradientBrush x:Key="MacroItemSelectedLeftBorderGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#E8A020" Offset="0"/>
        <GradientStop Color="#E8A020" Offset="1"/>
    </LinearGradientBrush>

    <!-- Accents -->
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimaryColor}"/>
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource AccentSecondaryColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="AccentSelectionBrush" Color="{StaticResource AccentSelectionColor}"/>
    
    <!-- Sidebar -->
    <SolidColorBrush x:Key="SidebarAccentBrush" Color="{StaticResource SidebarAccentColor}"/>
    <SolidColorBrush x:Key="SidebarAccentLightBrush" Color="{StaticResource SidebarAccentLightColor}"/>
    <SolidColorBrush x:Key="SidebarAccentSelectedBrush" Color="{StaticResource SidebarAccentSelectedColor}"/>
    <SolidColorBrush x:Key="SidebarAccentHoverBrush" Color="{StaticResource SidebarAccentHoverColor}"/>
    <SolidColorBrush x:Key="SidebarAccentBorderBrush" Color="{StaticResource SidebarAccentBorderColor}"/>
    
    <!-- Texte -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="{StaticResource TextOnAccentColor}"/>
    
    <!-- États -->
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="ErrorDimBrush" Color="{StaticResource ErrorColor}" Opacity="0.12"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    
    <!-- Bordures -->
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLightColor}"/>
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource BorderFocusColor}"/>
    <SolidColorBrush x:Key="BorderInternalBrush" Color="{StaticResource BorderInternalColor}"/>
    <SolidColorBrush x:Key="BorderMediumBrush" Color="{StaticResource BorderMediumColor}"/>
    <SolidColorBrush x:Key="BorderDarkBrush" Color="{StaticResource BorderDarkColor}"/>
    <SolidColorBrush x:Key="BorderMechanicalEdgeBrush" Color="{StaticResource BorderMechanicalEdgeColor}"/>
    <SolidColorBrush x:Key="BorderMechanicalInsetAccentBrush" Color="{StaticResource BorderMechanicalInsetAccentColor}"/>
    <!-- Cadre métallique biseauté (multi-ton, relief) -->
    <LinearGradientBrush x:Key="BorderMetallicBevelBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource BorderBevelHighlightColor}" Offset="0"/>
        <GradientStop Color="{StaticResource BorderLightColor}" Offset="0.35"/>
        <GradientStop Color="{StaticResource BorderBevelShadowColor}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Blocs d'action -->
    <SolidColorBrush x:Key="BlockKeyboardBrush" Color="{StaticResource BlockKeyboardColor}"/>
    <SolidColorBrush x:Key="BlockKeyboardDarkBrush" Color="{StaticResource BlockKeyboardDarkColor}"/>
    <SolidColorBrush x:Key="BlockMouseBrush" Color="{StaticResource BlockMouseColor}"/>
    <SolidColorBrush x:Key="BlockMouseDarkBrush" Color="{StaticResource BlockMouseDarkColor}"/>
    <SolidColorBrush x:Key="BlockTextBrush" Color="{StaticResource BlockTextColor}"/>
    <SolidColorBrush x:Key="BlockTextDarkBrush" Color="{StaticResource BlockTextDarkColor}"/>
    <SolidColorBrush x:Key="BlockDelayBrush" Color="{StaticResource BlockDelayColor}"/>
    <SolidColorBrush x:Key="BlockDelayDarkBrush" Color="{StaticResource BlockDelayDarkColor}"/>
    <SolidColorBrush x:Key="BlockLoopBrush" Color="{StaticResource BlockLoopColor}"/>
    <SolidColorBrush x:Key="BlockLoopDarkBrush" Color="{StaticResource BlockLoopDarkColor}"/>
    <SolidColorBrush x:Key="BlockRepeatGreenBrush" Color="{StaticResource BlockRepeatGreenColor}"/>
    <SolidColorBrush x:Key="BlockConditionBrush" Color="{StaticResource BlockConditionColor}"/>
    <SolidColorBrush x:Key="BlockConditionDarkBrush" Color="{StaticResource BlockConditionDarkColor}"/>
    <SolidColorBrush x:Key="BlockSiRedBrush" Color="{StaticResource BlockSiRedColor}"/>
    <SolidColorBrush x:Key="BlockVariableBrush" Color="{StaticResource BlockVariableColor}"/>
    <SolidColorBrush x:Key="BlockVariableDarkBrush" Color="{StaticResource BlockVariableDarkColor}"/>
    <SolidColorBrush x:Key="BlockActionBorderBrush" Color="{StaticResource BlockActionBorderColor}"/>
    <SolidColorBrush x:Key="EditorGridBrush" Color="{StaticResource EditorGridColor}"/>

    <!-- Barre d'outils : dégradés marqués (haut clair → bas bien plus sombre) -->
    <LinearGradientBrush x:Key="BlockKeyboardToolbarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BlockKeyboardColor}" Offset="0"/>
        <GradientStop Color="{StaticResource BlockKeyboardDarkColor}" Offset="0.4"/>
        <GradientStop Color="{StaticResource BlockKeyboardToolbarBottomColor}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BlockMouseToolbarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BlockMouseColor}" Offset="0"/>
        <GradientStop Color="{StaticResource BlockMouseDarkColor}" Offset="0.4"/>
        <GradientStop Color="{StaticResource BlockMouseToolbarBottomColor}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BlockTextToolbarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BlockTextColor}" Offset="0"/>
        <GradientStop Color="{StaticResource BlockTextDarkColor}" Offset="0.4"/>
        <GradientStop Color="{StaticResource BlockTextToolbarBottomColor}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BlockVariableToolbarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BlockVariableColor}" Offset="0"/>
        <GradientStop Color="{StaticResource BlockVariableDarkColor}" Offset="0.4"/>
        <GradientStop Color="{StaticResource BlockVariableToolbarBottomColor}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BlockDelayToolbarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BlockDelayColor}" Offset="0"/>
        <GradientStop Color="{StaticResource BlockDelayDarkColor}" Offset="0.4"/>
        <GradientStop Color="{StaticResource BlockDelayToolbarBottomColor}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BlockConditionToolbarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BlockConditionColor}" Offset="0"/>
        <GradientStop Color="{StaticResource BlockConditionDarkColor}" Offset="0.4"/>
        <GradientStop Color="{StaticResource BlockConditionToolbarBottomColor}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BlockLoopToolbarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BlockLoopColor}" Offset="0"/>
        <GradientStop Color="{StaticResource BlockLoopDarkColor}" Offset="0.4"/>
        <GradientStop Color="{StaticResource BlockLoopToolbarBottomColor}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentSecondaryToolbarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource AccentSecondaryColor}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentPressedColor}" Offset="0.5"/>
        <GradientStop Color="#352010" Offset="1"/>
    </LinearGradientBrush>
    <!-- Enregistrer (rouge) / Arrêter (gris) - barre d'outils éditeur -->
    <LinearGradientBrush x:Key="RecordToolbarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource ErrorColor}" Offset="0"/>
        <GradientStop Color="#A83A3A" Offset="0.4"/>
        <GradientStop Color="#8F2828" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="StopToolbarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BackgroundTertiaryColor}" Offset="0"/>
        <GradientStop Color="#282530" Offset="0.4"/>
        <GradientStop Color="#1E1B22" Offset="1"/>
    </LinearGradientBrush>
    <!-- Exécuter (vert) / Pause (gris) - barre d'outils éditeur -->
    <LinearGradientBrush x:Key="ExecuteToolbarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource SuccessColor}" Offset="0"/>
        <GradientStop Color="#3EA47B" Offset="0.4"/>
        <GradientStop Color="#2D8A6A" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PauseToolbarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BackgroundTertiaryColor}" Offset="0"/>
        <GradientStop Color="#282530" Offset="0.4"/>
        <GradientStop Color="#1E1B22" Offset="1"/>
    </LinearGradientBrush>

    <!-- ══════════════════════════════════════════════════════════════════════
         Effets d'ombre et glow
         ══════════════════════════════════════════════════════════════════════ -->
    
    <!-- Ombre standard (rgba(0,0,0,0.35)) -->
    <DropShadowEffect x:Key="ShadowSubtle" 
                      Color="Black" 
                      Opacity="0.35" 
                      BlurRadius="10" 
                      ShadowDepth="2"
                      Direction="270"/>

    <!-- Colonne gauche : ombre externe très légère à droite (4px 0 40px rgba(0,0,0,0.6)) -->
    <DropShadowEffect x:Key="ShadowSidebarColumn" 
                      Color="Black" 
                      Opacity="0.6" 
                      BlurRadius="40" 
                      ShadowDepth="4"
                      Direction="0"/>
    
    <!-- Ombre pour les blocs d'action (normal) -->
    <DropShadowEffect x:Key="ShadowActionBlock" 
                      Color="Black" 
                      Opacity="0.35" 
                      BlurRadius="8" 
                      ShadowDepth="2"
                      Direction="270"/>
    
    <!-- Glow ambre (v2) -->
    <DropShadowEffect x:Key="ShadowActionBlockHover" 
                      Color="#E8A020" 
                      Opacity="0.35" 
                      BlurRadius="12" 
                      ShadowDepth="0"
                      Direction="270"/>
    <DropShadowEffect x:Key="ShadowButtonHover" 
                      Color="#E8A020" 
                      Opacity="0.18" 
                      BlurRadius="8" 
                      ShadowDepth="0"
                      Direction="270"/>
    <DropShadowEffect x:Key="ShadowCtaHover" 
                      Color="#E8A020" 
                      Opacity="0.35" 
                      BlurRadius="24" 
                      ShadowDepth="0"
                      Direction="270"/>
    <DropShadowEffect x:Key="ShadowMacroItemTraitGlow" 
                      Color="#E8A020" 
                      Opacity="0.4" 
                      BlurRadius="8" 
                      ShadowDepth="0"
                      Direction="0"/>
    <DropShadowEffect x:Key="ShadowMacroItemTraitGlowLight" 
                      Color="#E8A020" 
                      Opacity="0.3" 
                      BlurRadius="6" 
                      ShadowDepth="0"
                      Direction="0"/>
    <DropShadowEffect x:Key="ShadowPanelPropertiesHover" 
                      Color="#E8A020" 
                      Opacity="0.2" 
                      BlurRadius="14" 
                      ShadowDepth="0"
                      Direction="270"/>

    <!-- Élévation légère (champs TextBox panneau Propriétés) -->
    <DropShadowEffect x:Key="ShadowTextBoxElevation" 
                      Color="Black" 
                      Opacity="0.22" 
                      BlurRadius="6" 
                      ShadowDepth="2"
                      Direction="270"/>

    <!-- ══════════════════════════════════════════════════════════════════════
         CornerRadius (réduits pour un look plus sobre)
         ══════════════════════════════════════════════════════════════════════ -->
    
    <CornerRadius x:Key="RadiusActionBlock">6</CornerRadius>
    <CornerRadius x:Key="RadiusButton">5</CornerRadius>
    <CornerRadius x:Key="RadiusPanel">6</CornerRadius>
    <CornerRadius x:Key="RadiusTextInput">4</CornerRadius>
    <CornerRadius x:Key="RadiusWindow">8</CornerRadius>
    <CornerRadius x:Key="RadiusSmall">2</CornerRadius>
    <CornerRadius x:Key="RadiusMacroCard">14</CornerRadius>

    <!-- Colonne gauche (rail v2) : fond vert très sombre -->
    <Color x:Key="SidebarColumnTopColor">#0D0F0D</Color>
    <Color x:Key="SidebarColumnBottomColor">#080A08</Color>
    <LinearGradientBrush x:Key="SidebarColumnGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource SidebarColumnTopColor}" Offset="0"/>
        <GradientStop Color="{StaticResource SidebarColumnBottomColor}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Colonne macros (v2) : fond vert sombre -->
    <Color x:Key="MacroColumnBackgroundColor">#111311</Color>
    <LinearGradientBrush x:Key="MacroColumnBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0D0F0D" Offset="0"/>
        <GradientStop Color="#080A08" Offset="1"/>
    </LinearGradientBrush>

    <Color x:Key="MacroItemBackgroundColor">#161916</Color>
    <SolidColorBrush x:Key="MacroItemBackgroundBrush" Color="{StaticResource MacroItemBackgroundColor}"/>

    <!-- Liste macros v2 : texte vert gris, actif = trait ambre -->
    <Color x:Key="MacroItemNormalForegroundColor">#C8D4C8</Color>
    <SolidColorBrush x:Key="MacroItemNormalForegroundBrush" Color="{StaticResource MacroItemNormalForegroundColor}"/>
    <Color x:Key="MacroItemHoverBackgroundColor">#161916</Color>
    <SolidColorBrush x:Key="MacroItemHoverBackgroundBrush" Color="{StaticResource MacroItemHoverBackgroundColor}"/>
    <Color x:Key="MacroItemSelectedGradientLightColor">#161916</Color>
    <Color x:Key="MacroItemSelectedGradientDarkColor">#111311</Color>
    <LinearGradientBrush x:Key="MacroItemSelectedBackgroundBrush" StartPoint="0,1" EndPoint="1,0">
        <GradientStop Color="{StaticResource MacroItemSelectedGradientLightColor}" Offset="0"/>
        <GradientStop Color="{StaticResource MacroItemSelectedGradientDarkColor}" Offset="1"/>
    </LinearGradientBrush>
    <Color x:Key="SeparatorSubtleColor">#262D26</Color>
    <SolidColorBrush x:Key="SeparatorSubtleBrush" Color="{StaticResource SeparatorSubtleColor}"/>

</ResourceDictionary>
